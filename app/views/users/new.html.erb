<% content_for :title, "Novo usuário · Dokivo" %>

<div class="mx-auto max-w-xl space-y-6">
  <header>
    <p class="text-xs font-semibold uppercase tracking-wide text-accent">Usuários</p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Novo usuário</h1>
    <p class="mt-2 text-sm leading-relaxed text-zinc-600">Vincule o usuário a uma conta e defina função e acesso.</p>
  </header>

  <div class="app-card p-6 sm:p-8">
    <%= render "form", user: @user %>
  </div>

  <p>
    <%= link_to "← Voltar aos usuários", users_path, class: "text-sm font-medium text-zinc-600 no-underline transition-colors hover:text-zinc-900" %>
  </p>
</div>
