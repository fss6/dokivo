<% content_for :title, t("users.new.title") + t("users.title_suffix") %>

<div class="mx-auto max-w-xl space-y-6">
  <header>
    <p class="text-xs font-semibold uppercase tracking-wide text-accent"><%= t("users.breadcrumb") %></p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl"><%= t("users.new.title") %></h1>
    <p class="mt-2 text-sm leading-relaxed text-zinc-600"><%= t("users.new.subtitle") %></p>
  </header>

  <div class="app-card p-6 sm:p-8">
    <%= render "form", user: @user %>
  </div>

  <p>
    <%= link_to t("users.links.back_to_index"), users_path, class: "text-sm font-medium text-zinc-600 no-underline transition-colors hover:text-zinc-900" %>
  </p>
</div>
