<p style="margin:0 0 16px;font-size:15px;line-height:1.55;color:#3f3f46;">
  <%= t("mailers.reset_password.greeting_html", email: h(@resource.email)).html_safe %>
</p>

<p style="margin:0 0 28px;font-size:15px;line-height:1.55;color:#3f3f46;">
  <%= t("mailers.reset_password.body") %>
</p>

<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 0 28px;">
  <tr>
    <td align="center" style="border-radius:8px;background-color:#1a6fff;">
      <%= link_to t("mailers.reset_password.cta"),
            edit_password_url(@resource, reset_password_token: @token),
            style: "display:inline-block;padding:14px 28px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:8px;" %>
    </td>
  </tr>
</table>

<p style="margin:0 0 12px;font-size:13px;line-height:1.5;color:#71717a;">
  <%= t("mailers.reset_password.link_fallback") %>
</p>
<p style="margin:0 0 24px;font-size:12px;line-height:1.5;color:#a1a1aa;word-break:break-all;">
  <%= edit_password_url(@resource, reset_password_token: @token) %>
</p>

<p style="margin:0;font-size:13px;line-height:1.55;color:#71717a;">
  <%= t("mailers.reset_password.ignore_note") %>
</p>
