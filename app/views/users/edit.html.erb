<% content_for :title, t("users.edit.title") + t("users.title_suffix") %>

<div class="mx-auto max-w-xl space-y-6">
  <header>
    <p class="text-xs font-semibold uppercase tracking-wide text-accent"><%= t("users.breadcrumb") %></p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl"><%= t("users.edit.title") %></h1>
    <p class="mt-2 text-sm leading-relaxed text-zinc-600"><%= t("users.edit.subtitle") %></p>
  </header>

  <div class="app-card p-6 sm:p-8">
    <%= render "form", user: @user %>
  </div>

  <p class="flex flex-wrap gap-x-4 gap-y-2 text-sm">
    <%= link_to t("users.edit.link_show"), user_path(@user), class: "font-medium text-accent no-underline hover:text-teal-700" %>
    <span class="text-zinc-300" aria-hidden="true">|</span>
    <%= link_to t("users.links.back_to_index"), users_path, class: "font-medium text-zinc-600 no-underline hover:text-zinc-900" %>
  </p>
</div>
