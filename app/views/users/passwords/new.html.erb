<% content_for :title, "#{t('devise.passwords.new.title')}#{t('users.title_suffix')}" %>

<section class="app-card overflow-hidden">
  <div class="border-b border-zinc-200/80 bg-white/80 px-6 py-6 sm:px-8">
    <h1 class="text-2xl font-bold tracking-tight text-zinc-900"><%= t("devise.passwords.new.title") %></h1>
    <p class="mt-2 text-sm text-zinc-600"><%= t("devise.passwords.new.subtitle") %></p>
  </div>

  <div class="px-6 py-6 sm:px-8">
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
      <%= render "users/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "app-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "app-input", placeholder: t("auth.sessions.email_placeholder") %>
      </div>

      <%= f.submit t("devise.passwords.new.submit"), class: "app-btn-primary w-full py-2.5 text-sm font-semibold" %>
    <% end %>

    <div class="mt-6 border-t border-zinc-200/80 pt-5 text-sm text-zinc-600">
      <div class="space-y-2 [&_a]:font-medium [&_a]:text-accent [&_a]:transition-colors [&_a:hover]:text-teal-600">
        <%= render "users/shared/links" %>
      </div>
    </div>
  </div>
</section>
