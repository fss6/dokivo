<% content_for :title, "#{t('devise.passwords.edit.title')}#{t('users.title_suffix')}" %>

<section class="app-card overflow-hidden">
  <div class="border-b border-zinc-200/80 bg-white/80 px-6 py-6 sm:px-8">
    <h1 class="text-2xl font-bold tracking-tight text-zinc-900"><%= t("devise.passwords.edit.title") %></h1>
    <p class="mt-2 text-sm text-zinc-600"><%= t("devise.passwords.edit.subtitle") %></p>
  </div>

  <div class="px-6 py-6 sm:px-8">
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
      <%= render "users/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div>
        <%= f.label :password, class: "app-label" %>
        <% if @minimum_password_length %>
          <p class="mb-2 text-xs text-zinc-500"><%= t("devise.passwords.edit.min_hint", count: @minimum_password_length) %></p>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "app-input" %>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "app-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "app-input" %>
      </div>

      <%= f.submit t("devise.passwords.edit.submit"), class: "app-btn-primary w-full py-2.5 text-sm font-semibold" %>
    <% end %>

    <div class="mt-6 border-t border-zinc-200/80 pt-5 text-sm text-zinc-600">
      <div class="space-y-2 [&_a]:font-medium [&_a]:text-accent [&_a]:transition-colors [&_a:hover]:text-teal-600">
        <%= render "users/shared/links" %>
      </div>
    </div>
  </div>
</section>
