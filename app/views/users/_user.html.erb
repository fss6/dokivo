<%# Detalhes do usuário (show) %>
<div id="<%= dom_id user %>" class="app-card overflow-hidden">
  <dl class="grid divide-y divide-zinc-100 sm:grid-cols-2 lg:grid-cols-4 sm:divide-x sm:divide-y-0">
    <div class="px-5 py-4 sm:px-6 sm:py-5 lg:col-span-2">
      <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500"><%= User.human_attribute_name(:name) %></dt>
      <dd class="mt-1 text-base font-medium text-zinc-900"><%= user.name %></dd>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5 lg:col-span-2">
      <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500"><%= User.human_attribute_name(:email) %></dt>
      <dd class="mt-1 text-base font-medium text-zinc-900"><%= user.email %></dd>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500"><%= User.human_attribute_name(:role) %></dt>
      <dd class="mt-1 text-base font-medium text-zinc-900"><%= user.role_label %></dd>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500"><%= t("users.index.table.status") %></dt>
      <dd class="mt-1">
        <% if user.enabled? %>
          <span class="inline-flex rounded-md bg-teal-50 px-2.5 py-1 text-sm font-medium text-teal-800 ring-1 ring-inset ring-teal-600/20"><%= t("users.status.active") %></span>
        <% else %>
          <span class="inline-flex rounded-md bg-zinc-100 px-2.5 py-1 text-sm font-medium text-zinc-600"><%= t("users.status.inactive") %></span>
        <% end %>
      </dd>
    </div>
  </dl>
  <div class="border-t border-zinc-100 px-5 py-4 sm:px-6 sm:py-5">
    <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500"><%= t("users.show.access.heading") %></p>
    <dl class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <div>
        <dt class="text-xs font-medium text-zinc-500"><%= t("users.show.access.sign_in_count") %></dt>
        <dd class="mt-1 text-sm font-medium text-zinc-900 tabular-nums"><%= user.sign_in_count %></dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-zinc-500"><%= t("users.show.access.last_sign_in") %></dt>
        <dd class="mt-1 text-sm font-medium text-zinc-900">
          <% if user.last_sign_in_at %>
            <%= l(user.last_sign_in_at, format: :short) %>
          <% else %>
            <span class="text-zinc-500"><%= t("users.show.access.never_signed_in") %></span>
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-zinc-500"><%= t("users.show.access.current_sign_in") %></dt>
        <dd class="mt-1 text-sm font-medium text-zinc-900">
          <%= user.current_sign_in_at ? l(user.current_sign_in_at, format: :short) : content_tag(:span, t("users.show.access.empty_datetime"), class: "text-zinc-500") %>
        </dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-zinc-500"><%= t("users.show.access.last_sign_in_ip") %></dt>
        <dd class="mt-1 text-sm font-medium text-zinc-900"><%= user.last_sign_in_ip.presence || content_tag(:span, t("users.show.access.empty_datetime"), class: "text-zinc-500") %></dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-zinc-500"><%= t("users.show.access.current_sign_in_ip") %></dt>
        <dd class="mt-1 text-sm font-medium text-zinc-900"><%= user.current_sign_in_ip.presence || content_tag(:span, t("users.show.access.empty_datetime"), class: "text-zinc-500") %></dd>
      </div>
      <% if user.remember_created_at %>
        <div>
          <dt class="text-xs font-medium text-zinc-500"><%= t("users.show.access.remember_since") %></dt>
          <dd class="mt-1 text-sm font-medium text-zinc-900"><%= l(user.remember_created_at, format: :short) %></dd>
        </div>
      <% end %>
    </dl>
  </div>
</div>
