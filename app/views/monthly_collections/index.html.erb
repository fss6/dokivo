<% content_for :title, "Competências · Dokivo" %>

<div class="space-y-6">
  <header>
    <p class="text-xs font-semibold uppercase tracking-wide text-accent">Envio e validação</p>
    <h1 class="text-2xl font-semibold text-zinc-900 sm:text-3xl">Competências</h1>
    <p class="mt-1 text-sm text-zinc-600">Cliente ativo: <strong><%= current_client.name %></strong>.</p>
  </header>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,22rem)_1fr] lg:items-start">
    <section class="app-card p-5 sm:p-6">
      <h2 class="text-base font-semibold tracking-tight text-zinc-900">Nova competência</h2>
      <p class="mt-1 text-sm text-zinc-600">Selecione o mês e ano de referência.</p>

      <%= form_with url: monthly_collections_path, method: :post, local: true, class: "mt-5 space-y-4" do %>
        <div>
          <label for="monthly_collection_period" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Competência</label>
          <%= text_field_tag :period,
                Date.current.strftime("%Y/%m"),
                id: "monthly_collection_period",
                required: true,
                autocomplete: "off",
                data: { controller: "month-picker" },
                class: "mt-1 w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-800" %>
        </div>
        <div>
          <%= button_tag "Criar competência", type: "submit", class: "app-btn-primary w-full sm:w-auto" %>
        </div>
      <% end %>
    </section>

    <section class="app-card min-w-0 overflow-hidden">
      <% if @periods.any? %>
        <ul class="divide-y divide-zinc-100">
          <% @periods.each do |collection| %>
            <% period = collection.period.beginning_of_month %>
            <li class="flex items-center justify-between gap-3 px-5 py-4 sm:px-6">
              <div class="min-w-0">
                <p class="text-sm font-medium text-zinc-900"><%= l(period, format: "%m/%Y") %></p>
                <p class="text-xs text-zinc-500">Acompanhe as pendências desta competência.</p>
              </div>
              <%= link_to "Abrir", monthly_collection_path(period.strftime("%Y-%m")), class: "app-btn-secondary shrink-0 text-xs" %>
            </li>
          <% end %>
        </ul>
        <% if @pagy.pages > 1 %>
          <div class="border-t border-zinc-100 px-4 py-3 sm:px-6">
            <%== @pagy.series_nav %>
          </div>
        <% end %>
      <% else %>
        <div class="px-5 py-8 text-sm text-zinc-600 sm:px-6">Nenhuma competência disponível.</div>
      <% end %>
    </section>
  </div>
</div>
