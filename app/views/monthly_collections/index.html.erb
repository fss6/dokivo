<% content_for :title, "Competências · Dokivo" %>

<div class="space-y-6" data-controller="app-form-modal">
  <header>
    <p class="text-xs font-semibold uppercase tracking-wide text-accent">Envio e validação</p>
    <h1 class="text-2xl font-semibold text-zinc-900 sm:text-3xl">Competências</h1>
    <p class="mt-1 text-sm text-zinc-600">Cliente ativo: <strong><%= current_client.name %></strong>.</p>
  </header>

  <div class="flex justify-end">
    <button type="button" class="app-btn-primary w-full sm:w-auto" data-action="click->app-form-modal#open">
      Criar competência
    </button>
  </div>

  <dialog
    data-app-form-modal-target="dialog"
    data-action="click->app-form-modal#backdropClick"
    class="z-[200] m-0 max-h-[min(90vh,calc(100vh-2rem))] w-[min(100%,28rem)] max-w-[min(28rem,calc(100vw-2rem))] border-0 bg-transparent p-0 shadow-none outline-none [&:not([open])]:hidden [&::backdrop]:bg-black/50 [&::backdrop]:backdrop-blur-[1px]"
    style="position: fixed; left: 50%; top: 50%; transform: translate(-50%, -50%);"
    aria-labelledby="create-competency-modal-title"
  >
    <div class="flex max-h-[min(90vh,calc(100vh-2rem))] flex-col overflow-hidden rounded-2xl border border-zinc-200/90 bg-white text-zinc-900 shadow-[0_25px_50px_-12px_rgb(0_0_0/0.25)]">
      <div class="border-b border-zinc-100 px-5 py-4">
        <h2 id="create-competency-modal-title" class="text-base font-semibold tracking-tight text-zinc-900">Criar competência</h2>
        <p class="mt-1 text-sm text-zinc-600">Selecione o mês de referência para gerar checklist e pasta da coleta.</p>
      </div>
      <div class="px-5 py-4">
        <%= form_with url: monthly_collections_path, method: :post, local: true, class: "space-y-3" do %>
          <div>
            <label for="monthly_collection_period" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Competência</label>
            <input id="monthly_collection_period" name="period" type="month" value="<%= Date.current.strftime("%Y-%m") %>" class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm text-zinc-800" required>
          </div>
          <div class="flex flex-col-reverse gap-2 pt-2 sm:flex-row sm:justify-end">
            <button type="button" class="app-btn-secondary" data-action="click->app-form-modal#close">Cancelar</button>
            <button type="submit" class="app-btn-primary">Criar competência</button>
          </div>
        <% end %>
      </div>
    </div>
  </dialog>

  <section class="app-card overflow-hidden">
    <% if @periods.any? %>
      <ul class="divide-y divide-zinc-100">
        <% @periods.each do |collection| %>
          <% period = collection.period.beginning_of_month %>
          <li class="flex items-center justify-between px-5 py-4 sm:px-6">
            <div>
              <p class="text-sm font-medium text-zinc-900"><%= l(period, format: "%m/%Y") %></p>
              <p class="text-xs text-zinc-500">Acompanhe as pendências desta competência.</p>
            </div>
            <%= link_to "Abrir", monthly_collection_path(period.strftime("%Y-%m")), class: "app-btn-secondary text-xs" %>
          </li>
        <% end %>
      </ul>
      <% if @pagy.pages > 1 %>
        <div class="border-t border-zinc-100 px-4 py-3 sm:px-6">
          <%== @pagy.series_nav %>
        </div>
      <% end %>
    <% else %>
      <div class="px-5 py-8 text-sm text-zinc-600 sm:px-6">Nenhuma competência disponível.</div>
    <% end %>
  </section>
</div>
