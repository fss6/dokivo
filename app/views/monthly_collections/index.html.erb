<% content_for :title, "Competências · Dokivo" %>

<div class="space-y-6">
  <header>
    <p class="text-xs font-semibold uppercase tracking-wide text-accent">Envio e validação</p>
    <h1 class="text-2xl font-semibold text-zinc-900 sm:text-3xl">Competências</h1>
    <p class="mt-1 text-sm text-zinc-600">Cliente ativo: <strong><%= current_client.name %></strong>.</p>
  </header>

  <section class="app-card p-4 sm:p-5">
    <h2 class="text-sm font-semibold text-zinc-900">Criar competência</h2>
    <%= form_with url: monthly_collections_path, method: :post, local: true, class: "mt-3 grid gap-3 sm:grid-cols-2" do %>
      <div>
        <label for="period" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Competência</label>
        <input id="period" name="period" type="month" value="<%= Date.current.strftime("%Y-%m") %>" class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm text-zinc-800">
      </div>
      <div class="flex items-end">
        <button type="submit" class="app-btn-primary w-full">Criar competência</button>
      </div>
    <% end %>
  </section>

  <section class="app-card overflow-hidden">
    <% if @periods.any? %>
      <ul class="divide-y divide-zinc-100">
        <% @periods.each do |period| %>
          <li class="flex items-center justify-between px-5 py-4 sm:px-6">
            <div>
              <p class="text-sm font-medium text-zinc-900"><%= l(period, format: "%m/%Y") %></p>
              <p class="text-xs text-zinc-500">Checklist da competência</p>
            </div>
            <%= link_to "Abrir", monthly_collection_path(period.strftime("%Y-%m")), class: "app-btn-secondary text-xs" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="px-5 py-8 text-sm text-zinc-600 sm:px-6">Nenhuma competência disponível.</div>
    <% end %>
  </section>
</div>
