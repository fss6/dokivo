<% content_for :title, "Novo plano · Docfy" %>

<div class="mx-auto max-w-xl space-y-6">
  <header>
    <p class="text-xs font-semibold uppercase tracking-wide text-accent">Coleções</p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Novo plano</h1>
    <p class="mt-2 text-sm leading-relaxed text-zinc-600">Adicione um item à coleção com nome, valor e status.</p>
  </header>

  <div class="app-card p-6 sm:p-8">
    <%= render "form", plan: @plan %>
  </div>

  <p>
    <%= link_to "← Voltar aos planos", plans_path, class: "text-sm font-medium text-zinc-600 no-underline transition-colors hover:text-zinc-900" %>
  </p>
</div>
