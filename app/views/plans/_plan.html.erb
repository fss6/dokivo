<div id="<%= dom_id plan %>" class="app-card overflow-hidden">
  <dl class="grid divide-y divide-zinc-100 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Nome</dt>
      <dd class="mt-1 text-base font-medium text-zinc-900"><%= plan.name %></dd>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Preço</dt>
      <dd class="mt-1 text-base font-medium text-zinc-900 tabular-nums"><%= number_to_currency(plan.price, unit: "R$ ", separator: ",", delimiter: ".") %></dd>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Status</dt>
      <dd class="mt-1">
        <span class="inline-flex rounded-md bg-zinc-100 px-2.5 py-1 text-sm font-medium text-zinc-800"><%= plan.status %></span>
      </dd>
    </div>
  </dl>
</div>
