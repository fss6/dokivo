<%# locals: plan %>
<%= link_to plan, class: "app-card app-card-hover group block overflow-hidden no-underline" do %>
  <div class="aspect-[4/3] bg-gradient-to-br from-zinc-100 to-zinc-200/80">
    <div class="flex h-full items-center justify-center text-zinc-400">
      <svg class="h-12 w-12 opacity-60 transition-transform duration-200 group-hover:scale-105" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
    </div>
  </div>
  <div class="border-t border-zinc-100 p-4">
    <p class="font-medium text-zinc-900 group-hover:text-accent"><%= plan.name %></p>
    <p class="mt-1 text-sm text-zinc-500">Ref. · <%= number_to_currency(plan.price, unit: "R$ ", separator: ",", delimiter: ".") %></p>
    <div class="mt-3 flex items-center gap-2">
      <span class="inline-flex rounded-md bg-zinc-100 px-2 py-0.5 text-xs font-medium text-zinc-700"><%= plan.status %></span>
      <span class="text-xs text-zinc-400">Pré-visualização</span>
    </div>
  </div>
<% end %>
