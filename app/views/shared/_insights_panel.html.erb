<section class="space-y-8" aria-labelledby="insights-tags-heading">
  <div>
    <h2 id="insights-tags-heading" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Tags geradas por IA</h2>
    <p class="mt-1 text-sm text-zinc-600">Sugestões automáticas com base nos seus ativos recentes.</p>
    <div class="mt-4 flex flex-wrap gap-2">
      <% %w[Contratos Faturas OCR Aprovado Risco-baixo Fiscal-2026].each do |tag| %>
        <span class="inline-flex items-center rounded-md border border-zinc-200 bg-zinc-50 px-2.5 py-1 text-xs font-medium text-zinc-700 shadow-sm"><%= tag %></span>
      <% end %>
      <span class="inline-flex items-center rounded-md border border-accent/30 bg-accent/10 px-2.5 py-1 text-xs font-medium text-teal-800">+ Nova tag</span>
    </div>
  </div>

  <div>
    <h2 class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Saúde da coleção</h2>
    <p class="mt-1 text-sm text-zinc-600">Índice agregado de completude e consistência.</p>
    <div class="app-card mt-4 p-4">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="text-3xl font-semibold tracking-tight text-zinc-900">87<span class="text-lg font-normal text-zinc-400">/100</span></p>
          <p class="mt-1 text-xs text-zinc-500">Estável nas últimas 24 h</p>
        </div>
        <div class="relative h-16 w-16 shrink-0 rounded-full border-4 border-zinc-100 bg-zinc-50" style="background: conic-gradient(#14b8a6 0deg 313deg, rgb(244 244 245) 313deg 360deg);" aria-hidden="true">
          <div class="absolute inset-1 rounded-full bg-white"></div>
        </div>
      </div>
      <div class="mt-4 space-y-2">
        <% [{ label: "Metadados", w: "92%" }, { label: "Duplicatas", w: "78%" }, { label: "Classificação IA", w: "88%" }].each do |row| %>
          <div>
            <div class="flex justify-between text-xs text-zinc-600">
              <span><%= row[:label] %></span>
            </div>
            <div class="mt-1 h-1.5 overflow-hidden rounded-full bg-zinc-100">
              <div class="h-full rounded-full bg-accent" style="width: <%= row[:w] %>"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
