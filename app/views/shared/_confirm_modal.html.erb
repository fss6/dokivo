<%# locals: (heading:, body_prefix:, body_suffix:, confirm_text:, cancel_text: nil) %>
<% cancel_text ||= t("shared.confirm_modal.cancel") %>
<%# Não use flex/grid/display no <dialog>: isso sobrescreve o display:none do UA e o modal aparece fechado. %>
<dialog
  data-app-confirm-modal-target="dialog"
  data-action="click->app-confirm-modal#backdropClick"
  class="z-[200] m-0 w-[min(100%,24rem)] max-w-[min(24rem,calc(100vw-2rem))] border-0 bg-transparent p-0 shadow-none outline-none [&:not([open])]:hidden [&::backdrop]:bg-black/50 [&::backdrop]:backdrop-blur-[1px]"
  style="position: fixed; left: 50%; top: 50%; transform: translate(-50%, -50%);"
  aria-labelledby="app-confirm-modal-title"
>
  <div class="flex max-h-[min(90vh,calc(100vh-2rem))] flex-col overflow-hidden rounded-2xl border border-zinc-200/90 bg-white text-zinc-900 shadow-[0_25px_50px_-12px_rgb(0_0_0/0.25)]">
    <div class="border-b border-zinc-100 px-5 py-4">
      <h2 id="app-confirm-modal-title" class="text-base font-semibold tracking-tight text-zinc-900" data-app-confirm-modal-target="heading">
        <%= heading %>
      </h2>
      <p class="mt-2 text-sm leading-relaxed text-zinc-600">
        <span data-app-confirm-modal-target="bodyPrefix"><%= body_prefix %></span><span class="font-medium text-zinc-800" data-app-confirm-modal-target="itemLabel">—</span><span data-app-confirm-modal-target="bodySuffix"><%= body_suffix %></span>
      </p>
    </div>
    <div class="flex flex-col-reverse gap-2 px-5 py-4 sm:flex-row sm:justify-end sm:gap-3">
      <button
        type="button"
        class="inline-flex cursor-pointer items-center justify-center rounded-lg border border-zinc-200 bg-white px-4 py-2.5 text-sm font-medium text-zinc-700 shadow-sm transition-colors hover:bg-zinc-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-zinc-400"
        data-action="click->app-confirm-modal#close"
      >
        <%= cancel_text %>
      </button>
      <%= form_with url: "#", method: :delete, data: { app_confirm_modal_target: "form", turbo_frame: "_top" }, class: "inline-block w-full sm:w-auto" do %>
        <button
          type="submit"
          data-app-confirm-modal-target="confirmButton"
          class="inline-flex w-full cursor-pointer items-center justify-center rounded-lg border border-red-200 bg-red-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-red-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600"
        >
          <%= confirm_text %>
        </button>
      <% end %>
    </div>
  </div>
</dialog>
