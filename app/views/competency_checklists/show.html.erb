<% content_for :title, "Checklist da competência · Dokivo" %>
<% pending_count = @items.count(&:pending?) %>
<% received_count = @items.count(&:received?) %>
<% validated_count = @items.count(&:validated?) %>
<% total_count = @items.size %>
<% progress_percent = total_count.positive? ? ((validated_count.to_f / total_count) * 100).round : 0 %>

<div class="space-y-6" data-controller="app-confirm-modal app-form-modal">
  <header class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-medium text-zinc-500">Cliente <%= @folder.client.name %></p>
      <h1 class="text-2xl font-semibold text-zinc-900">Portal de Coleta</h1>
      <p class="text-sm text-zinc-600">Upload e checklist da competência no mesmo fluxo.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Voltar para pasta", @folder, class: "app-btn-secondary" %>
    </div>
  </header>

  <section class="app-card p-4 sm:p-5">
    <%= form_with url: folder_competency_checklist_path(@folder), method: :get, local: true, class: "flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between" do %>
      <div>
        <label for="period" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Competência</label>
        <input id="period" name="period" type="month" value="<%= @period.strftime("%Y-%m") %>" class="mt-1 rounded-lg border border-zinc-300 px-3 py-2 text-sm text-zinc-800 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20">
      </div>
      <button type="submit" class="app-btn-primary">Aplicar</button>
    <% end %>
  </section>

  <%= render "documents/upload",
        folder: @folder,
        upload_context: "competency_checklist",
        compact: false,
        extra_hidden_fields: { period: @period.strftime("%Y-%m") } %>

  <section class="app-card max-w-3xl overflow-hidden p-0">
    <div class="border-b border-zinc-100 bg-zinc-50/60 px-5 py-4 sm:px-6">
      <h2 class="text-base font-semibold text-zinc-900">Checklist da competência</h2>
      <p class="mt-1 text-xs text-zinc-500"><%= validated_count %>/<%= total_count %> itens concluídos · <%= received_count %> recebidos · <%= pending_count %> pendentes</p>
      <div class="mt-2 h-2 w-full rounded-full bg-zinc-200">
        <div class="h-2 rounded-full bg-emerald-500 transition-all" style="width: <%= progress_percent %>%"></div>
      </div>
    </div>

    <% if @items.any? %>
      <ul class="space-y-1 p-3 sm:p-4">
        <% @items.each do |item| %>
          <% row_classes = item.validated? ? "bg-emerald-50/70" : "bg-zinc-50 hover:bg-zinc-100/80" %>
          <% checked_by_document = item.last_document.present? %>
          <li class="rounded-md px-2 py-1.5 transition-colors <%= row_classes %>" data-controller="app-form-modal">
            <div class="flex items-start gap-2">
              <% if item.validated? %>
                <%= button_to mark_pending_folder_competency_checklist_path(@folder, period: @period.strftime("%Y-%m")), method: :patch, params: { item_id: item.id }, class: "mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded border border-emerald-600 bg-emerald-600 text-white", title: "Reabrir item" do %>
                  ✓
                <% end %>
              <% elsif checked_by_document %>
                <span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded border border-emerald-600 bg-emerald-600 text-white" title="Documento vinculado">
                  ✓
                </span>
              <% else %>
                <%= button_to mark_validated_folder_competency_checklist_path(@folder, period: @period.strftime("%Y-%m")), method: :patch, params: { item_id: item.id }, class: "mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded border border-zinc-400 bg-white text-transparent hover:border-emerald-600 hover:text-emerald-600", title: "Marcar como validado" do %>
                  ✓
                <% end %>
              <% end %>

              <div class="min-w-0 flex-1">
                <p class="text-sm <%= item.validated? ? "text-zinc-500 line-through" : "font-medium text-zinc-900" %>"><%= item.name_snapshot %></p>
                <p class="text-xs text-zinc-500">
                  <% if item.last_document.present? %>
                    <%= link_to document_file_label(item.last_document), item.last_document, class: "font-medium text-accent no-underline hover:text-teal-700" %>
                    · Recebido em <%= l(item.last_document.created_at, format: :short) %>
                  <% else %>
                    Ainda sem arquivo correspondente nesta competência.
                  <% end %>
                </p>

                <div class="mt-2 flex flex-wrap items-center gap-2">
                  <% if item.last_document.present? %>
                    <%= button_to "Desvincular",
                          detach_document_folder_competency_checklist_path(@folder, period: @period.strftime("%Y-%m")),
                          method: :patch,
                          params: { item_id: item.id },
                          class: "text-xs text-zinc-500 underline decoration-zinc-300 underline-offset-2 hover:text-zinc-700" %>
                  <% end %>
                </div>
              </div>

              <div class="flex items-center gap-1">
                <% unless item.last_document.present? %>
                  <button type="button"
                          class="inline-flex h-7 w-7 items-center justify-center rounded-md text-zinc-400 transition-colors hover:bg-zinc-100 hover:text-zinc-700"
                          title="Vincular documento"
                          aria-label="Vincular documento ao item <%= item.name_snapshot %>"
                          data-action="click->app-form-modal#open">
                    <%= heroicon "paper-clip", variant: :outline, options: { class: "h-4 w-4" } %>
                  </button>
                <% end %>

                <%= button_tag type: "button",
                      class: "inline-flex h-7 w-7 items-center justify-center rounded-md text-zinc-400 transition-colors hover:bg-red-50 hover:text-red-600",
                      title: "Excluir item",
                      aria: { label: "Excluir item #{item.name_snapshot}" },
                      data: app_confirm_modal_open_data(
                        url: remove_item_folder_competency_checklist_path(@folder, period: @period.strftime("%Y-%m"), item_id: item.id),
                        item_label: item.name_snapshot,
                        heading: "Remover item do checklist?",
                        body_prefix: "Você está prestes a remover o item ",
                        body_suffix: ". Esta ação não pode ser desfeita.",
                        confirm_text: "Remover item",
                        confirm_variant: "danger"
                      ) do %>
                  <%= heroicon "trash", variant: :outline, options: { class: "h-4 w-4" } %>
                <% end %>
              </div>
            </div>

            <% unless item.last_document.present? %>
              <dialog
                data-app-form-modal-target="dialog"
                data-action="click->app-form-modal#backdropClick"
                class="z-[200] m-0 max-h-[min(90vh,calc(100vh-2rem))] w-[min(100%,28rem)] max-w-[min(28rem,calc(100vw-2rem))] border-0 bg-transparent p-0 shadow-none outline-none [&:not([open])]:hidden [&::backdrop]:bg-black/50 [&::backdrop]:backdrop-blur-[1px]"
                style="position: fixed; left: 50%; top: 50%; transform: translate(-50%, -50%);"
                aria-labelledby="attach-doc-item-<%= item.id %>"
              >
                <div class="flex max-h-[min(90vh,calc(100vh-2rem))] flex-col overflow-hidden rounded-2xl border border-zinc-200/90 bg-white text-zinc-900 shadow-[0_25px_50px_-12px_rgb(0_0_0/0.25)]">
                  <div class="border-b border-zinc-100 px-5 py-4">
                    <h2 id="attach-doc-item-<%= item.id %>" class="text-base font-semibold tracking-tight text-zinc-900">Vincular documento</h2>
                    <p class="mt-1 text-sm text-zinc-600"><%= item.name_snapshot %></p>
                  </div>
                  <div class="px-5 py-4">
                    <%= form_with url: attach_document_folder_competency_checklist_path(@folder, period: @period.strftime("%Y-%m")), method: :patch, local: true, class: "space-y-3" do %>
                      <%= hidden_field_tag :item_id, item.id %>
                      <div>
                        <label class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Documento</label>
                        <%= select_tag :document_id,
                              options_for_select(@available_documents.map { |doc| ["#{document_file_label(doc)} · #{l(doc.created_at, format: :short)}", doc.id] }),
                              include_blank: "Selecione um documento...",
                              required: true,
                              class: "mt-1 w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-700" %>
                      </div>
                      <div class="flex flex-col-reverse gap-2 pt-2 sm:flex-row sm:justify-end">
                        <button type="button" class="app-btn-secondary" data-action="click->app-form-modal#close">Cancelar</button>
                        <button type="submit" class="app-btn-primary">Vincular</button>
                      </div>
                    <% end %>
                  </div>
                </div>
              </dialog>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="px-5 py-6 text-sm text-zinc-600 sm:px-6">Nenhum item nessa competência. Crie o primeiro abaixo.</div>
    <% end %>

    <div class="border-t border-zinc-100 bg-zinc-50/40 px-4 py-3 sm:px-5">
      <button type="button" class="app-btn-primary text-xs" data-action="click->app-form-modal#open">
        Adicionar item
      </button>
    </div>
  </section>

  <dialog
    data-app-form-modal-target="dialog"
    data-action="click->app-form-modal#backdropClick"
    class="z-[200] m-0 max-h-[min(90vh,calc(100vh-2rem))] w-[min(100%,28rem)] max-w-[min(28rem,calc(100vw-2rem))] border-0 bg-transparent p-0 shadow-none outline-none [&:not([open])]:hidden [&::backdrop]:bg-black/50 [&::backdrop]:backdrop-blur-[1px]"
    style="position: fixed; left: 50%; top: 50%; transform: translate(-50%, -50%);"
    aria-labelledby="add-item-modal-title"
  >
    <div class="flex max-h-[min(90vh,calc(100vh-2rem))] flex-col overflow-hidden rounded-2xl border border-zinc-200/90 bg-white text-zinc-900 shadow-[0_25px_50px_-12px_rgb(0_0_0/0.25)]">
      <div class="border-b border-zinc-100 px-5 py-4">
        <h2 id="add-item-modal-title" class="text-base font-semibold tracking-tight text-zinc-900">Adicionar item ao checklist</h2>
      </div>
      <div class="px-5 py-4">
        <%= form_with url: create_template_item_folder_competency_checklist_path(@folder, period: @period.strftime("%Y-%m")), method: :post, local: true, class: "space-y-3" do %>
          <div>
            <label for="folder_item_name" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Nome do item</label>
            <input id="folder_item_name" name="name" required placeholder="Ex.: DARF PIS/COFINS" class="mt-1 w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-800 placeholder:text-zinc-400">
          </div>
          <div>
            <label for="folder_item_terms" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Palavras-chave (vírgula)</label>
            <input id="folder_item_terms" name="match_terms" placeholder="darf, pis, cofins" class="mt-1 w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-800 placeholder:text-zinc-400">
          </div>
          <div class="flex flex-col-reverse gap-2 pt-2 sm:flex-row sm:justify-end">
            <button type="button" class="app-btn-secondary" data-action="click->app-form-modal#close">Cancelar</button>
            <button type="submit" class="app-btn-primary">Adicionar item</button>
          </div>
        <% end %>
      </div>
    </div>
  </dialog>

  <%= render "shared/confirm_modal",
        heading: "Remover item do checklist?",
        body_prefix: "Você está prestes a remover o item ",
        body_suffix: ". Esta ação não pode ser desfeita.",
        confirm_text: "Remover item" %>
</div>
