<% content_for :title, "Dokivo — Gestão inteligente de documentos" %>

<% content_for :head do %>
<style>
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }
  .syne { font-family: 'Syne', sans-serif; }
  .heading { font-family: 'Plus Jakarta Sans', sans-serif; }
  @keyframes pulse-dot { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.8); } }
  @keyframes blink-cur { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
  @keyframes scroll-x { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @keyframes fade-up { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
  .anim-pulse-dot { animation: pulse-dot 2s infinite; }
  .anim-blink { animation: blink-cur 1s infinite; display:inline-block; width:2px; height:13px; background:#1A6FFF; margin-left:2px; vertical-align:middle; }
  .anim-scroll-x { animation: scroll-x 22s linear infinite; width: max-content; }
  .anim-fade-up { animation: fade-up 0.7s ease both; }
  .d1 { animation-delay: 0.1s; } .d2 { animation-delay: 0.2s; }
  .d3 { animation-delay: 0.3s; } .d4 { animation-delay: 0.4s; }
  .d5 { animation-delay: 0.5s; } .d6 { animation-delay: 0.6s; }
  .d8 { animation-delay: 0.8s; }
  .feat-card { transition: all 0.25s; }
  .feat-card:hover { background: rgba(26,111,255,0.06) !important; border-color: rgba(26,111,255,0.3) !important; transform: translateY(-3px); }
  .mock-doc { transition: all 0.2s; }
  .mock-doc:hover { background: rgba(26,111,255,0.08); border-color: rgba(26,111,255,0.3); }
  .steps-row { position: relative; }
  .steps-row::before {
    content: '';
    position: absolute;
    top: 28px; left: 10%; right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(26,111,255,0.3), rgba(26,111,255,0.3), transparent);
    z-index: 0;
  }
  @media (max-width: 768px) {
    .steps-row::before { display: none; }
    .float-tag { display: none !important; }
  }
  .price-featured { background: rgba(26,111,255,0.13) !important; border-color: #1A6FFF !important; transform: scale(1.02); box-shadow: 0 0 60px rgba(26,111,255,0.15); }
  @media (max-width: 900px) { .price-featured { transform: none; box-shadow: none; } }
  details summary::-webkit-details-marker { display: none; }
  details[open] summary { color: #A8C8FF; }
</style>
<% end %>

<%# ─── NAV ─── %>
<nav class="sticky top-0 z-50 border-b" style="border-color:rgba(255,255,255,0.08);background:rgba(6,14,28,0.85);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);">
  <div class="mx-auto flex max-w-[1160px] items-center justify-between px-8 py-4">
    <a href="/" class="flex items-center gap-3 no-underline">
      <%= image_tag "/brand/logo.svg", alt: "Dokivo", class: "h-[38px] w-[38px] shrink-0 rounded-[10px]" %>
      <span class="logo-text">Dok<span>ivo</span></span>
    </a>
    <div class="flex items-center gap-2">
      <a href="#funcionalidades" class="hidden rounded-lg border px-5 py-2 text-sm font-medium transition hover:text-white sm:block" style="border-color:rgba(255,255,255,0.08);color:#C8D8EE;" onmouseover="this.style.borderColor='rgba(26,111,255,0.3)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">Funcionalidades</a>
      <a href="#precos" class="hidden rounded-lg border px-5 py-2 text-sm font-medium transition hover:text-white sm:block" style="border-color:rgba(255,255,255,0.08);color:#C8D8EE;" onmouseover="this.style.borderColor='rgba(26,111,255,0.3)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">Preços</a>
      <%= link_to "Entrar", new_user_session_path, class: "rounded-lg border px-5 py-2 text-sm font-medium transition hover:text-white", style: "border-color:rgba(255,255,255,0.08);color:#C8D8EE;" %>
      <%= link_to "Criar conta", new_user_registration_path, class: "rounded-lg bg-[#1A6FFF] px-5 py-2 text-sm font-semibold text-white transition hover:bg-[#4D8FFF]" %>
    </div>
  </div>
</nav>

<%# ─── HERO ─── %>
<section class="relative overflow-hidden px-8 pb-20 pt-24">
  <div class="pointer-events-none absolute left-1/2 top-[-200px] h-[600px] w-[600px] -translate-x-1/2 rounded-full" style="background:radial-gradient(circle,rgba(26,111,255,0.2) 0%,transparent 70%);filter:blur(80px);z-index:0;"></div>
  <div class="pointer-events-none absolute right-[-100px] top-[60%] h-[400px] w-[400px] rounded-full" style="background:radial-gradient(circle,rgba(26,111,255,0.12) 0%,transparent 70%);filter:blur(80px);z-index:0;"></div>
  <div class="pointer-events-none absolute left-[-80px] top-[30%] h-[300px] w-[300px] rounded-full" style="background:radial-gradient(circle,rgba(100,160,255,0.1) 0%,transparent 70%);filter:blur(80px);z-index:0;"></div>

  <div class="relative z-10 mx-auto grid max-w-[1160px] items-center gap-16 lg:grid-cols-2">
    <%# Copy side %>
    <div>
      <div class="anim-fade-up mb-7 inline-flex items-center gap-2 rounded-full border px-3.5 py-1.5" style="border-color:rgba(26,111,255,0.3);background:rgba(26,111,255,0.08);">
        <span class="anim-pulse-dot h-1.5 w-1.5 rounded-full bg-[#1A6FFF]"></span>
        <span class="text-[11px] font-semibold uppercase tracking-[0.06em] text-[#A8C8FF]">Gestão inteligente de documentos</span>
      </div>
      <h1 class="heading anim-fade-up d1 mb-6 font-extrabold leading-[1.08] tracking-[-0.03em] text-white" style="font-size:clamp(36px,4.5vw,54px);">
        Transforme documentos em <em class="not-italic text-[#4D8FFF]">informação útil</em> em segundos.
      </h1>
      <p class="anim-fade-up d2 mb-10 max-w-[480px] text-[17px] font-light leading-[1.7] text-[#8CA0BC]">
        O Dokivo transforma arquivos corporativos em conhecimento acessível. Faça upload, pergunte em linguagem natural e obtenha respostas precisas com rastreabilidade total.
      </p>
      <div class="anim-fade-up d3 flex flex-wrap items-center gap-3.5">
        <%= link_to new_user_registration_path, class: "inline-flex items-center gap-2 rounded-[10px] bg-[#1A6FFF] px-7 py-3.5 text-[15px] font-semibold text-white transition hover:bg-[#4D8FFF] hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(26,111,255,0.35)]" do %>
          Começar grátis
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <% end %>
        <a href="#como-funciona" class="rounded-[10px] border px-7 py-3.5 text-[15px] font-medium text-[#C8D8EE] transition hover:border-[rgba(26,111,255,0.3)] hover:text-white" style="border-color:rgba(255,255,255,0.12);">Ver como funciona</a>
      </div>
      <div class="anim-fade-up d4 mt-10 flex items-center gap-2.5 text-[13px] text-[#8CA0BC]">
        <div class="flex">
          <div class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-[#060E1C] bg-[#1A6FFF] text-[11px] font-semibold" style="margin-right:-8px;">AB</div>
          <div class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-[#060E1C] bg-[#0E4DAB] text-[11px] font-semibold" style="margin-right:-8px;">CF</div>
          <div class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-[#060E1C] bg-[#3D85E0] text-[11px] font-semibold" style="margin-right:-8px;">MR</div>
          <div class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-[#060E1C] bg-[#2060C0] text-[11px] font-semibold">TS</div>
        </div>
        <span>+200 empresas já usam o Dokivo</span>
      </div>
    </div>

    <%# Mockup side %>
    <div class="anim-fade-up d3 relative">
      <div class="float-tag absolute -right-4 -top-4 z-20 flex items-center gap-2 rounded-[10px] border px-3.5 py-2.5 text-[13px] font-medium text-white shadow-[0_8px_24px_rgba(0,0,0,0.4)]" style="background:rgba(17,34,64,0.95);border-color:rgba(26,111,255,0.3);" >
        <div class="flex h-7 w-7 items-center justify-center rounded-[7px]" style="background:rgba(40,200,100,0.15);">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3.5" stroke="#28C864" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        Contrato aprovado
      </div>

      <div class="relative overflow-hidden rounded-[20px] border p-6 shadow-[0_40px_80px_rgba(0,0,0,0.5),0_0_0_1px_rgba(255,255,255,0.04)_inset]" style="background:rgba(17,34,64,0.9);border-color:rgba(255,255,255,0.08);backdrop-filter:blur(8px);">
        <div class="absolute inset-x-0 top-0 h-px" style="background:linear-gradient(90deg,transparent,rgba(26,111,255,0.6),transparent);"></div>

        <div class="mb-5 flex items-center justify-between">
          <div class="flex gap-1.5">
            <div class="h-2.5 w-2.5 rounded-full bg-[#FF5F57]"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-[#FFBD2E]"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-[#28CA41]"></div>
          </div>
          <div class="rounded-md border px-3 py-1 text-[12px] text-[#8CA0BC]" style="background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.08);">dokivo.com.br</div>
        </div>

        <div class="mb-3.5 grid grid-cols-2 gap-2.5">
          <div class="rounded-[10px] border p-3.5" style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.08);">
            <div class="text-[11px] uppercase tracking-[0.06em] text-[#8CA0BC]">Documentos</div>
            <div class="syne mt-1.5 text-[26px] font-bold text-white">247</div>
          </div>
          <div class="rounded-[10px] border p-3.5" style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.08);">
            <div class="text-[11px] uppercase tracking-[0.06em] text-[#8CA0BC]">Consultados hoje</div>
            <div class="syne mt-1.5 text-[26px] font-bold text-white">38</div>
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <div class="mock-doc flex items-center gap-3 rounded-lg border p-2.5 px-3" style="background:rgba(255,255,255,0.03);border-color:rgba(255,255,255,0.08);">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-[7px] text-sm" style="background:rgba(255,80,80,0.15);">📄</div>
            <div class="min-w-0 flex-1">
              <div class="truncate text-[13px] font-medium text-white">Contrato ACME Corp — 2025</div>
              <div class="mt-0.5 text-[11px] text-[#8CA0BC]">PDF · 2,4 MB · há 2h</div>
            </div>
            <span class="shrink-0 rounded-[5px] px-2 py-0.5 text-[10px] font-semibold" style="background:rgba(255,180,0,0.15);color:#FFB400;">Pendente</span>
          </div>
          <div class="mock-doc flex items-center gap-3 rounded-lg border p-2.5 px-3" style="background:rgba(255,255,255,0.03);border-color:rgba(255,255,255,0.08);">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-[7px] text-sm" style="background:rgba(40,200,100,0.15);">📋</div>
            <div class="min-w-0 flex-1">
              <div class="truncate text-[13px] font-medium text-white">Política de Privacidade v3</div>
              <div class="mt-0.5 text-[11px] text-[#8CA0BC]">DOCX · 840 KB · ontem</div>
            </div>
            <span class="shrink-0 rounded-[5px] px-2 py-0.5 text-[10px] font-semibold" style="background:rgba(40,200,100,0.15);color:#28C864;">Aprovado</span>
          </div>
          <div class="mock-doc flex items-center gap-3 rounded-lg border p-2.5 px-3" style="background:rgba(255,255,255,0.03);border-color:rgba(255,255,255,0.08);">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-[7px] text-sm" style="background:rgba(26,111,255,0.15);">📊</div>
            <div class="min-w-0 flex-1">
              <div class="truncate text-[13px] font-medium text-white">Relatório Auditoria Q2</div>
              <div class="mt-0.5 text-[11px] text-[#8CA0BC]">PDF · 5,1 MB · 3 dias</div>
            </div>
            <span class="shrink-0 rounded-[5px] px-2 py-0.5 text-[10px] font-semibold" style="background:rgba(26,111,255,0.15);color:#A8C8FF;">Em revisão</span>
          </div>
        </div>

        <div class="mt-3.5 rounded-[10px] border p-3 px-3.5" style="background:rgba(26,111,255,0.08);border-color:rgba(26,111,255,0.3);">
          <div class="mb-1.5 text-[12px] text-[#A8C8FF]">💬 "Qual o prazo de entrega no contrato ACME?"</div>
          <div class="text-[13px] leading-[1.5] text-[#C8D8EE]">
            Conforme a Cláusula 4.2, o prazo é de <strong class="text-[#A8C8FF]">30 dias corridos</strong> após a assinatura, com prorrogação de até 15 dias.<span class="anim-blink"></span>
          </div>
        </div>
      </div>

      <div class="float-tag absolute -bottom-4 -left-4 z-20 flex items-center gap-2 rounded-[10px] border px-3.5 py-2.5 text-[13px] font-medium text-white shadow-[0_8px_24px_rgba(0,0,0,0.4)]" style="background:rgba(17,34,64,0.95);border-color:rgba(26,111,255,0.3);">
        <div class="flex h-7 w-7 items-center justify-center rounded-[7px]" style="background:rgba(26,111,255,0.15);">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5" stroke="#4D8FFF" stroke-width="1.2"/><path d="M7 4.5v3l2 1.5" stroke="#4D8FFF" stroke-width="1.2" stroke-linecap="round"/></svg>
        </div>
        Resposta em &lt; 2s
      </div>
    </div>
  </div>
</section>

<%# ─── PROBLEM / SOLUTION ─── %>
<section class="relative overflow-hidden py-24" id="funcionalidades">
  <div class="pointer-events-none absolute right-0 top-1/2 h-[500px] w-[500px] -translate-y-1/2 translate-x-1/3 rounded-full" style="background:radial-gradient(circle,rgba(26,111,255,0.09) 0%,transparent 70%);filter:blur(70px);"></div>
  <div class="mx-auto max-w-[1160px] px-8">
    <div class="mb-4 flex items-center gap-1.5 text-[12px] font-semibold uppercase tracking-[0.08em] text-[#A8C8FF]">
      O cenário atual
    </div>
    <h2 class="heading mb-4 font-extrabold leading-[1.1] tracking-[-0.02em] text-white" style="font-size:clamp(28px,3.5vw,42px);">Documentos espalhados custam<br>tempo e dinheiro.</h2>
    <p class="max-w-[540px] text-[17px] font-light leading-[1.7] text-[#8CA0BC]">Equipes modernas precisam de acesso rápido e inteligente ao conteúdo dos seus arquivos — não de buscas manuais intermináveis.</p>

    <div class="relative z-10 mt-14 grid gap-5 lg:grid-cols-2">
      <div class="rounded-[20px] border p-9" style="background:rgba(255,60,60,0.06);border-color:rgba(255,60,60,0.2);">
        <div class="mb-4 text-[11px] font-bold uppercase tracking-[0.1em] text-[#FF6B6B]">⚠ O problema</div>
        <h3 class="heading mb-3 text-[22px] font-bold leading-[1.25]">Arquivos dispersos, histórico perdido e retrabalho constante.</h3>
        <p class="mb-5 font-light leading-[1.7] text-[#8CA0BC]">Quando documentos ficam espalhados entre e-mails, pastas e sistemas, sua equipe gasta horas procurando informação em vez de decidir.</p>
        <div class="flex flex-col gap-2.5">
          <% ["Contratos desatualizados circulando por e-mail", "Horas perdidas para encontrar uma cláusula", "Risco de decisões com informação desatualizada"].each do |item| %>
            <div class="flex items-start gap-2.5 text-[14px] text-[#C8D8EE]">
              <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" fill="rgba(255,80,80,0.2)"/><path d="M5 5l4 4M9 5l-4 4" stroke="#FF6B6B" stroke-width="1.3" stroke-linecap="round"/></svg>
              <%= item %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="rounded-[20px] border p-9" style="background:rgba(26,111,255,0.09);border-color:rgba(26,111,255,0.28);">
        <div class="mb-4 text-[11px] font-bold uppercase tracking-[0.1em] text-[#A8C8FF]">✦ A solução</div>
        <h3 class="heading mb-3 text-[22px] font-bold leading-[1.25]">Um hub único que lê, entende e responde sobre seus documentos.</h3>
        <p class="mb-5 font-light leading-[1.7] text-[#8CA0BC]">Com o Dokivo, basta fazer upload e perguntar em linguagem natural. A IA localiza, interpreta e entrega a informação exata que você precisa.</p>
        <div class="flex flex-col gap-2.5">
          <% ["Busca semântica em todos os seus arquivos", "Respostas com referência exata ao trecho fonte", "Controle de acesso e rastreabilidade completa"].each do |item| %>
            <div class="flex items-start gap-2.5 text-[14px] text-[#C8D8EE]">
              <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" fill="rgba(26,111,255,0.2)"/><path d="M4 7l2 2 4-4" stroke="#A8C8FF" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <%= item %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ─── DEPOIMENTOS ─── %>
<section class="relative overflow-hidden border-b py-20" style="border-color:rgba(255,255,255,0.1);background:linear-gradient(180deg,#060E1C 0%,#091626 50%,#060E1C 100%);">
  <div class="pointer-events-none absolute left-1/4 top-0 h-[400px] w-[600px] -translate-x-1/2 rounded-full opacity-40" style="background:radial-gradient(circle,rgba(26,111,255,0.14) 0%,transparent 70%);filter:blur(60px);"></div>
  <div class="mx-auto max-w-[1160px] px-8 relative z-10">
    <div class="mb-4 text-[12px] font-semibold uppercase tracking-[0.08em] text-[#A8C8FF]">O que dizem os clientes</div>
    <h2 class="heading mb-12 font-extrabold leading-[1.1] tracking-[-0.02em] text-white" style="font-size:clamp(24px,3vw,36px);">Equipes que já economizam horas<br>com o Dokivo.</h2>

    <div class="grid gap-5 md:grid-cols-3">
      <% [
        ["Antes perdíamos horas procurando cláusulas em contratos antigos. Agora fazemos a pergunta e o Dokivo localiza o trecho em segundos, com a referência exata.",
         "Ana Lima", "Advogada Sênior", "Escritório Lima & Associados"],
        ["Implementamos em menos de um dia. Nossa equipe financeira parou de depender de e-mail para localizar documentos — tudo centralizado e pesquisável.",
         "Carlos Mendes", "CFO", "Grupo Meridian"],
        ["O controle de acesso por equipe foi decisivo para nós. Cada área vê apenas o que deve ver, com auditoria completa para nossas exigências de compliance.",
         "Rafaela Souza", "Gerente de Compliance", "TechFab Indústrias"]
      ].each_with_index do |(quote, name, role, company), i| %>
        <div class="flex flex-col rounded-[20px] border p-7" style="background:rgba(255,255,255,0.055);border-color:rgba(255,255,255,0.12);">
          <div class="mb-4 flex gap-0.5 text-[#1A6FFF]">
            <% 5.times do %><span class="text-[14px]">★</span><% end %>
          </div>
          <p class="flex-1 text-[14px] font-light leading-[1.75] text-[#C8D8EE]">"<%= quote %>"</p>
          <div class="mt-6 flex items-center gap-3 border-t pt-5" style="border-color:rgba(255,255,255,0.08);">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#1A6FFF] text-[12px] font-semibold text-white">
              <%= name.split.map(&:first).first(2).join %>
            </div>
            <div>
              <p class="text-[13px] font-semibold text-white"><%= name %></p>
              <p class="text-[11px] text-[#8CA0BC]"><%= role %> · <%= company %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ─── FEATURES ─── %>
<section class="relative overflow-hidden py-24" style="background:linear-gradient(180deg,#060E1C 0%,#070F1D 100%);">
  <div class="pointer-events-none absolute left-0 bottom-0 h-[400px] w-[500px] -translate-x-1/3 rounded-full" style="background:radial-gradient(circle,rgba(26,111,255,0.08) 0%,transparent 70%);filter:blur(70px);"></div>
  <div class="mx-auto max-w-[1160px] px-8">
    <div class="mb-4 text-[12px] font-semibold uppercase tracking-[0.08em] text-[#A8C8FF]">Funcionalidades</div>
    <h2 class="heading mb-14 font-extrabold leading-[1.1] tracking-[-0.02em] text-white" style="font-size:clamp(28px,3.5vw,42px);">Tudo que sua equipe precisa<br>para dominar os documentos.</h2>

    <div class="relative z-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <%# Card destaque — Chat com IA %>
