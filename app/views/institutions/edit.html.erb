<% content_for :title, "Editar #{@institution.name} · Dokivo" %>

<div class="mx-auto max-w-xl space-y-6">
  <header>
    <nav class="text-xs font-medium text-zinc-500" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-1.5">
        <li><%= link_to "Instituições", institutions_path, class: "text-zinc-500 no-underline hover:text-accent" %></li>
        <li aria-hidden="true">/</li>
        <li><%= link_to @institution.name, @institution, class: "text-zinc-500 no-underline hover:text-accent" %></li>
        <li aria-hidden="true">/</li>
        <li class="text-zinc-700">Editar</li>
      </ol>
    </nav>
    <h1 class="mt-3 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Editar instituição</h1>
  </header>

  <div class="app-card p-6 sm:p-8">
    <%= render "form", institution: @institution %>
  </div>

  <p>
    <%= link_to "← Voltar", @institution, class: "text-sm font-medium text-zinc-600 no-underline transition-colors hover:text-zinc-900" %>
  </p>
</div>
