<% content_for :title, "Nova instituição · Dokivo" %>

<div class="mx-auto max-w-xl space-y-6">
  <header>
    <p class="text-xs font-semibold uppercase tracking-wide text-accent">Instituições</p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Nova instituição</h1>
    <p class="mt-2 text-sm leading-relaxed text-zinc-600">Acrescente um nome que não exista na lista do sistema.</p>
  </header>

  <div class="app-card p-6 sm:p-8">
    <%= render "form", institution: @institution %>
  </div>

  <p>
    <%= link_to "← Voltar às instituições", institutions_path, class: "text-sm font-medium text-zinc-600 no-underline transition-colors hover:text-zinc-900" %>
  </p>
</div>
