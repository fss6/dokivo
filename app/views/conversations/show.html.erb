<% content_for :title, "Conversa · Dokivo" %>

<%= turbo_stream_from "conversation_#{@conversation.id}" %>

<div
  class="chat-module flex min-h-0 flex-1 flex-col overflow-hidden rounded-2xl border border-zinc-200/90 bg-white shadow-[var(--shadow-float)] lg:flex-row"
  data-controller="app-confirm-modal"
>
  <%= render "conversations/sidebar",
        account: @account,
        conversation: @conversation,
        sidebar_conversations: @sidebar_conversations %>

  <div class="flex min-h-0 min-w-0 flex-1 flex-col bg-gradient-to-b from-zinc-50/90 to-white" data-controller="chat">
    <header class="shrink-0 border-b border-zinc-200/90 bg-white/90 px-4 py-4 backdrop-blur-sm sm:px-6 lg:px-8">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div class="min-w-0">
          <h2 class="inline-flex items-center gap-2 text-lg font-bold tracking-tight text-zinc-900 sm:text-xl">
            <%= heroicon "sparkles", variant: :outline, options: { class: "h-5 w-5 text-accent", "aria-hidden": "true" } %>
            <span>Assistente de IA</span>
          </h2>
          <p class="mt-0.5 max-w-2xl text-sm leading-relaxed text-zinc-600">
            Faça perguntas sobre os documentos e obtenha respostas inteligentes com citações às fontes.
          </p>
          <div class="mt-3 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-zinc-500">
            <%= render "conversations/title_header_span", conversation: @conversation %>
            <span class="text-zinc-300" aria-hidden="true">·</span>
            <span><%= @document_count %> <%= @document_count == 1 ? "arquivo indexado" : "arquivos indexados" %></span>
            <% if @focus_document&.file&.attached? %>
              <span class="text-zinc-300" aria-hidden="true">·</span>
              <span class="text-zinc-600">Foco: <%= @focus_document.file.filename %></span>
            <% end %>
          </div>
        </div>
      </div>
    </header>

    <div class="flex min-h-0 flex-1 flex-col px-4 pb-5 pt-3 sm:px-6 lg:px-8 lg:pb-6">
      <div
        id="messages"
        data-chat-target="messages"
        class="flex min-h-0 flex-1 flex-col gap-5 overflow-y-auto overscroll-contain rounded-xl bg-zinc-100/60 p-4 sm:p-5 [scrollbar-gutter:stable]"
      >
        <%= render partial: "messages/message", collection: @messages, as: :message, locals: { account: @account } %>
      </div>

      <div id="chat-form" class="mt-4 shrink-0 border-t border-zinc-200/80 pt-4 pb-[max(0.25rem,env(safe-area-inset-bottom))]">
        <%= render "messages/chat_form",
              account: @account,
              conversation: @conversation,
              focus_document_id: @focus_document_id %>
      </div>
    </div>
  </div>

  <%= render "conversations/delete_modal" %>
</div>
