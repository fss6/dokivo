<% content_for :title, "Configurações · Dokivo" %>

<div class="space-y-6">
  <header>
    <p class="text-xs font-semibold uppercase tracking-wide text-accent">Sistema</p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Configurações</h1>
    <p class="mt-2 max-w-2xl text-sm leading-relaxed text-zinc-600">
      Defina comportamentos globais da conta.
    </p>
  </header>

  <section class="app-card p-5">
    <%= form_with model: @setting, url: settings_path, method: :patch, class: "space-y-5" do |form| %>
      <% if @setting.errors.any? %>
        <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900">
          <p class="font-medium">Não foi possível salvar as configurações.</p>
          <ul class="mt-2 list-inside list-disc space-y-0.5 text-red-800">
            <% @setting.errors.full_messages.each do |error| %>
              <li><%= error %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="rounded-md border border-zinc-200 px-4 py-3">
        <label class="flex cursor-pointer items-start justify-between gap-4">
          <div>
            <p class="text-sm font-medium text-zinc-900">Gerar tags automaticamente com IA</p>
            <p class="mt-1 text-sm text-zinc-500">
              Quando habilitado, os documentos processados recebem sugestões iniciais de tags.
            </p>
          </div>
          <%= form.check_box :generate_tags_automatically, class: "mt-1 h-4 w-4 rounded border-zinc-300 text-accent focus:ring-accent" %>
        </label>
      </div>

      <div>
        <%= form.submit "Salvar configurações", class: "app-btn-primary cursor-pointer border-0" %>
      </div>
    <% end %>
  </section>
</div>
