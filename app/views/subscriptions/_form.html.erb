<%= form_with(model: subscription, class: "space-y-6") do |form| %>
  <% if subscription.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900 shadow-[var(--shadow-card)]" role="alert">
      <% err_n = subscription.errors.count %>
      <p class="font-medium"><%= err_n %> <%= err_n == 1 ? "erro impediu" : "erros impediram" %> salvar esta assinatura:</p>
      <ul class="mt-2 list-inside list-disc space-y-0.5 text-red-800">
        <% subscription.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-5">
    <div>
      <%= form.label :account_id, "Conta", class: "app-label" %>
      <%= form.collection_select :account_id, Account.order(:name), :id, :name,
            { prompt: "Selecione uma conta" },
            class: "app-input" %>
    </div>

    <div>
      <%= form.label :plan_id, "Plano", class: "app-label" %>
      <%= form.collection_select :plan_id, Plan.order(:name), :id, :name,
            { prompt: "Selecione um plano" },
            class: "app-input" %>
    </div>

    <div>
      <%= form.label :status, "Status", class: "app-label" %>
      <%= form.select :status, subscription_status_options, {}, class: "app-input" %>
    </div>

    <div>
      <%= form.label :current_period_end, "Fim do período atual", class: "app-label" %>
      <%= form.datetime_field :current_period_end, class: "app-input" %>
    </div>

    <div>
      <%= form.label :trial_ends_at, "Trial até", class: "app-label" %>
      <%= form.datetime_field :trial_ends_at, class: "app-input" %>
    </div>

    <div>
      <%= form.label :canceled_at, "Cancelada em", class: "app-label" %>
      <%= form.datetime_field :canceled_at, class: "app-input" %>
    </div>
  </div>

  <div class="flex flex-col-reverse gap-3 border-t border-zinc-100 pt-6 sm:flex-row sm:justify-end">
    <%= link_to "Cancelar", subscriptions_path, class: "app-btn-secondary text-center sm:text-left" %>
    <%= form.submit subscription.persisted? ? "Atualizar assinatura" : "Criar assinatura", class: "app-btn-primary cursor-pointer border-0" %>
  </div>
<% end %>
