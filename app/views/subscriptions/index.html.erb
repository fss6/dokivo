<% content_for :title, "Assinaturas · Docfy" %>

<div class="space-y-8">
  <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-accent">Cobrança</p>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Assinaturas</h1>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-zinc-600">
        Acompanhe planos, status e datas de período por conta.
      </p>
    </div>
    <%= link_to "Nova assinatura", new_subscription_path, class: "app-btn-primary w-full shrink-0 sm:w-auto" %>
  </header>

  <% if @subscriptions.any? %>
    <div class="app-card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full text-left text-sm">
          <thead>
            <tr class="border-b border-zinc-200 bg-zinc-50/90 text-xs font-semibold uppercase tracking-wide text-zinc-500">
              <th class="px-4 py-3 font-semibold">Conta</th>
              <th class="hidden px-4 py-3 font-semibold sm:table-cell">Plano</th>
              <th class="px-4 py-3 font-semibold">Status</th>
              <th class="hidden px-4 py-3 font-semibold lg:table-cell">Fim do período</th>
              <th class="px-4 py-3 text-right font-semibold">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-100">
            <%= render partial: "subscriptions/subscription_row", collection: @subscriptions, as: :subscription %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="app-card px-6 py-16 text-center">
      <p class="text-sm font-medium text-zinc-900">Nenhuma assinatura cadastrada</p>
      <p class="mt-1 text-sm text-zinc-500">Registre uma assinatura vinculada a uma conta e um plano.</p>
      <%= link_to "Nova assinatura", new_subscription_path, class: "app-btn-primary mt-6 inline-flex" %>
    </div>
  <% end %>
</div>
