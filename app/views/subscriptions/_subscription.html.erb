<div id="<%= dom_id subscription %>" class="app-card overflow-hidden">
  <div class="grid divide-y divide-zinc-100 sm:grid-cols-2 sm:divide-x sm:divide-y-0">
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Conta</p>
      <p class="mt-1 text-base font-medium text-zinc-900">
        <% if subscription.account %>
          <%= link_to subscription.account.name, account_path(subscription.account), class: "text-accent no-underline hover:text-teal-700" %>
        <% else %>
          —
        <% end %>
      </p>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Plano</p>
      <p class="mt-1 text-base font-medium text-zinc-900">
        <% if subscription.plan %>
          <%= link_to subscription.plan.name, plan_path(subscription.plan), class: "text-accent no-underline hover:text-teal-700" %>
        <% else %>
          —
        <% end %>
      </p>
    </div>
  </div>
  <div class="grid divide-y divide-zinc-100 border-t border-zinc-100 sm:grid-cols-2 sm:divide-x sm:divide-y-0">
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Status</p>
      <p class="mt-2">
        <span class="inline-flex rounded-md px-2.5 py-1 text-sm font-medium <%= subscription_status_badge_classes(subscription.status) %>">
          <%= subscription_status_label(subscription.status) %>
        </span>
      </p>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Fim do período atual</p>
      <p class="mt-1 text-sm tabular-nums text-zinc-900"><%= format_subscription_datetime(subscription.current_period_end) %></p>
    </div>
  </div>
  <div class="grid divide-y divide-zinc-100 border-t border-zinc-100 sm:grid-cols-2 sm:divide-x sm:divide-y-0">
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Trial até</p>
      <p class="mt-1 text-sm tabular-nums text-zinc-900"><%= format_subscription_datetime(subscription.trial_ends_at) %></p>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Cancelada em</p>
      <p class="mt-1 text-sm tabular-nums text-zinc-900"><%= format_subscription_datetime(subscription.canceled_at) %></p>
    </div>
  </div>
</div>
