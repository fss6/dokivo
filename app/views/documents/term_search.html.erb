<% content_for :title, "Busca por termo · Dokivo" %>

<div class="space-y-6">
  <header>
    <p class="text-xs font-semibold uppercase tracking-wide text-accent">Documentos</p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Busca por termo</h1>
    <p class="mt-2 max-w-2xl text-sm leading-relaxed text-zinc-600">
      Encontre arquivos por palavras presentes no conteúdo, resumo ou tags.
    </p>
  </header>

  <section class="app-card p-5">
    <%= form_with url: documents_term_search_path, method: :get, class: "flex flex-col gap-3 sm:flex-row sm:items-end" do |form| %>
      <div class="w-full">
        <%= form.label :q, "Termo de busca", class: "app-label" %>
        <%= form.text_field :q,
              value: @query,
              class: "app-input",
              placeholder: "Ex: corregedoria, escala, contrato...",
              autocomplete: "off" %>
      </div>
      <%= form.submit "Buscar", class: "app-btn-primary border-0 cursor-pointer" %>
    <% end %>
  </section>

  <%= render "documents/tag_search_results", documents: @documents %>
</div>
