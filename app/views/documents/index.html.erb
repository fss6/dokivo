<% content_for :title, "Documentos · #{@folder.name} · Docfy" %>

<div class="space-y-8">
  <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-accent">Pastas</p>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Documentos</h1>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-zinc-600">
        Todos os arquivos em <span class="font-medium text-zinc-800"><%= @folder.name %></span>
        (<%= link_to @folder.account.name, account_path(@folder.account), class: "text-accent no-underline hover:text-teal-700" %>).
      </p>
    </div>
    <%= link_to "Voltar à pasta", folder_path(@folder), class: "app-btn-secondary w-full shrink-0 text-center sm:w-auto" %>
  </header>

  <%= render "upload", folder: @folder, upload_context: "list" %>

  <% if @documents.any? %>
    <div class="app-card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full text-left text-sm">
          <thead>
            <tr class="border-b border-zinc-200 bg-zinc-50/90 text-xs font-semibold uppercase tracking-wide text-zinc-500">
              <th class="px-4 py-3 font-semibold">Arquivo</th>
              <th class="hidden px-4 py-3 font-semibold sm:table-cell">Usuário</th>
              <th class="px-4 py-3 font-semibold">Status</th>
              <th class="hidden px-4 py-3 font-semibold lg:table-cell">Atualizado</th>
              <th class="px-4 py-3 text-right font-semibold">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-100">
            <%= render partial: "documents/document_row", collection: @documents, as: :document, locals: { in_folder: true } %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="app-card px-6 py-12 text-center">
      <p class="text-sm font-medium text-zinc-900">Nenhum documento nesta pasta</p>
      <p class="mt-1 text-sm text-zinc-500">Use o formulário acima para enviar o primeiro arquivo.</p>
    </div>
  <% end %>
</div>
