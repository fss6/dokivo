<% content_for :title, "Documento · Docfy" %>

<div class="space-y-6">
  <header class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-accent">Pastas</p>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">
        <%= document_file_label(@document) %>
      </h1>
      <p class="mt-1 text-sm text-zinc-500">
        Em <%= link_to @document.folder.name, folder_path(@document.folder), class: "text-accent no-underline hover:text-teal-700" %>
      </p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Documentos da pasta", folder_documents_path(@document.folder), class: "app-btn-secondary" %>
      <%= link_to "Pasta", folder_path(@document.folder), class: "app-btn-ghost border border-zinc-200" %>
    </div>
  </header>

  <%= render @document %>

  <div class="app-card border-red-100 bg-red-50/30 p-4 sm:p-5">
    <p class="text-sm font-medium text-zinc-800">Zona de risco</p>
    <p class="mt-1 text-sm text-zinc-600">Excluir remove permanentemente este registro e o arquivo anexado.</p>
    <%= button_to "Excluir documento", @document, method: :delete,
          form: { class: "mt-4 inline" },
          data: { turbo_confirm: "Excluir este documento? Esta ação não pode ser desfeita." },
          class: "app-btn-danger cursor-pointer" %>
  </div>
</div>
