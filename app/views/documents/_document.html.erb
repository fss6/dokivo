<div id="<%= dom_id document %>" class="app-card overflow-hidden">
  <div class="grid divide-y divide-zinc-100 sm:grid-cols-2 sm:divide-x sm:divide-y-0">
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Arquivo</p>
      <p class="mt-1 text-base font-medium text-zinc-900"><%= document_file_label(document) %></p>
      <% if document.file.attached? %>
        <p class="mt-2">
          <%= link_to rails_blob_path(document.file, disposition: "attachment"),
                class: "inline-flex items-center gap-1.5 text-sm font-medium text-accent no-underline hover:text-teal-700" do %>
            <%= heroicon "arrow-down-tray", variant: :outline, options: { class: "h-4 w-4 shrink-0", "aria-hidden": "true" } %>
            <span>Baixar</span>
          <% end %>
        </p>
      <% end %>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Status</p>
      <p class="mt-2">
        <span class="inline-flex rounded-md px-2.5 py-1 text-sm font-medium <%= document_status_badge_classes(document.status) %>">
          <%= document_status_label(document.status) %>
        </span>
      </p>
    </div>
  </div>
  <div class="grid divide-y divide-zinc-100 border-t border-zinc-100 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Conta</p>
      <p class="mt-1 text-sm font-medium text-zinc-900">
        <% if document.account %>
          <%= link_to document.account.name, account_path(document.account), class: "text-accent no-underline hover:text-teal-700" %>
        <% else %>
          —
        <% end %>
      </p>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Usuário</p>
      <p class="mt-1 text-sm font-medium text-zinc-900">
        <% if document.user %>
          <%= link_to document.user.name.presence || document.user.email, user_path(document.user), class: "text-accent no-underline hover:text-teal-700" %>
        <% else %>
          —
        <% end %>
      </p>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Pasta</p>
      <p class="mt-1 text-sm font-medium text-zinc-900">
        <% if document.folder %>
          <%= link_to document.folder.name, folder_path(document.folder), class: "text-accent no-underline hover:text-teal-700" %>
        <% else %>
          —
        <% end %>
      </p>
    </div>
  </div>
  <% chunks = document.embedding_records.ordered_for_display %>
  <% has_text = document.content.present? || document.summary.present? || chunks.any? %>
  <div class="border-t border-zinc-100">
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Etiquetas</p>
      <div class="mt-2 space-y-3">
        <% if document.tags.any? %>
          <div class="flex flex-wrap gap-2">
            <% document.tags.each do |tag| %>
              <div class="inline-flex items-center gap-1 rounded-full bg-zinc-100 px-2.5 py-1 text-xs font-medium text-zinc-700">
                <span><%= tag %></span>
                <%= button_to "x",
                      remove_tag_document_path(document, tag: tag),
                      method: :delete,
                      class: "rounded-full px-1 text-zinc-500 transition-colors hover:bg-zinc-200 hover:text-zinc-800",
                      form: { class: "inline" } %>
              </div>
            <% end %>
          </div>
        <% else %>
          <span class="text-sm text-zinc-500">—</span>
        <% end %>

        <div class="grid grid-cols-1 gap-3 lg:grid-cols-2">
          <section class="rounded-lg border border-zinc-200 bg-zinc-50/70 px-4 py-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Adicionar tag</p>
            <%= form_with url: add_tag_document_path(document), method: :patch, class: "mt-3 flex flex-col gap-2 sm:flex-row sm:items-end" do |form| %>
              <div class="w-full">
                <%= form.label :tag, "Nova tag", class: "app-label" %>
                <%= form.text_field :tag, class: "app-input", placeholder: "Ex: nota fiscal, contrato, etc.", autocomplete: "off" %>
              </div>
              <%= form.submit "Adicionar", class: "app-btn-secondary cursor-pointer border-0" %>
            <% end %>
          </section>

          <% if document.tags.any? %>
            <section class="rounded-lg border border-zinc-200 bg-zinc-50/70 px-4 py-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Editar tag</p>
              <%= form_with url: replace_tag_document_path(document), method: :patch, class: "mt-3 space-y-2" do |form| %>
                <div>
                  <%= form.label :old_tag, "Tag atual", class: "app-label" %>
                  <%= form.select :old_tag, options_for_select(document.tags), {}, class: "app-input" %>
                </div>
                <div>
                  <%= form.label :new_tag, "Novo valor", class: "app-label" %>
                  <%= form.text_field :new_tag, class: "app-input", placeholder: "Novo texto da tag", autocomplete: "off" %>
                </div>
                <div>
                  <%= form.submit "Atualizar", class: "app-btn-secondary cursor-pointer border-0 w-full sm:w-auto" %>
                </div>
              <% end %>
            </section>
          <% end %>
        </div>
      </div>
    </div>
    <% if has_text %>
    <div class="grid divide-y divide-zinc-100 border-t border-zinc-100 sm:grid-cols-2 sm:divide-x sm:divide-y-0">
      <% if document.content.present? %>
        <div class="px-5 py-4 sm:px-6 sm:py-5">
          <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Conteúdo</p>
          <p class="mt-1 whitespace-pre-wrap text-sm text-zinc-800"><%= document.content %></p>
        </div>
      <% elsif chunks.any? %>
        <div class="px-5 py-4 sm:px-6 sm:py-5">
          <details class="group">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3 rounded-lg py-0.5 [&::-webkit-details-marker]:hidden">
              <span class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Conteúdo (OCR)</span>
              <%= heroicon "chevron-down", variant: :outline, options: { class: "h-5 w-5 shrink-0 text-zinc-400 transition-transform duration-200 group-open:rotate-180", "aria-hidden": "true" } %>
            </summary>
            <div class="mt-3 space-y-6 border-t border-zinc-100 pt-4">
              <% chunks.each do |chunk| %>
                <div>
                  <p class="text-xs font-medium text-zinc-500">Página <%= chunk.page_number %></p>
                  <p class="mt-1 whitespace-pre-wrap text-sm text-zinc-800"><%= chunk.content %></p>
                </div>
              <% end %>
            </div>
          </details>
        </div>
      <% end %>
      <% if document.summary.present? %>
        <div class="px-5 py-4 sm:px-6 sm:py-5">
          <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Resumo</p>
          <p class="mt-1 whitespace-pre-wrap text-sm text-zinc-800"><%= document.summary %></p>
        </div>
      <% end %>
    </div>
    <% end %>
  </div>
</div>
