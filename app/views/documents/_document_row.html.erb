<% in_folder = local_assigns.fetch(:in_folder, false) %>
<tr
  class="transition-colors hover:bg-zinc-50/80"
  <% if local_assigns[:folder_explorer] %>
    draggable="true"
    data-controller="folder-explorer"
    data-folder-explorer-document-id-value="<%= document.id %>"
    data-action="dragstart->folder-explorer#dragStart dragend->folder-explorer#dragEnd"
  <% end %>
>
  <td class="px-4 py-3">
    <span class="font-medium text-zinc-900"><%= document_file_label(document) %></span>
    <small class="mt-0.5 block text-xs text-zinc-500">Atualizado em <%= l(document.updated_at, format: :short) %></small>
  </td>
  <% if in_folder %>
    <td class="hidden px-4 py-3 sm:table-cell">
      <% if document.user %>
        <%= link_to document.user.name.presence || document.user.email, user_path(document.user), class: "text-sm text-zinc-600 no-underline hover:text-accent" %>
      <% else %>
        —
      <% end %>
    </td>
  <% else %>
    <td class="hidden px-4 py-3 sm:table-cell">
      <% if document.account %>
        <%= link_to document.account.name, account_path(document.account), class: "text-sm text-zinc-600 no-underline hover:text-accent" %>
      <% else %>
        —
      <% end %>
    </td>
    <td class="hidden px-4 py-3 md:table-cell">
      <% if document.folder %>
        <%= link_to document.folder.name, folder_path(document.folder), class: "text-sm text-zinc-600 no-underline hover:text-accent" %>
      <% else %>
        —
      <% end %>
    </td>
  <% end %>
  <td class="px-4 py-3">
    <span class="inline-flex rounded-md px-2 py-0.5 text-xs font-medium <%= document_status_badge_classes(document.status) %>">
      <%= document_status_label(document.status) %>
    </span>
  </td>
  <td class="px-4 py-3 text-right">
    <div class="flex flex-wrap items-center justify-end gap-2">
      <%= link_to document,
            class: "app-btn-secondary inline-flex items-center justify-center px-2.5 py-1.5 text-xs",
            title: "Ver documento",
            aria: { label: "Ver documento" } do %>
        <%= heroicon "eye", variant: :outline, options: { class: "h-4 w-4", "aria-hidden": "true" } %>
      <% end %>
      <%= button_tag type: "button",
            class: "app-btn-danger inline-flex items-center justify-center cursor-pointer px-2.5 py-1.5 text-xs",
            title: "Excluir documento",
            aria: { label: "Excluir documento" },
            data: app_confirm_modal_open_data(url: document_path(document), item_label: document_file_label(document)) do %>
        <%= heroicon "trash", variant: :outline, options: { class: "h-4 w-4", "aria-hidden": "true" } %>
      <% end %>
    </div>
  </td>
</tr>
