<% upload_context = local_assigns.fetch(:upload_context, "list") %>

<div class="my-4 rounded-xl border border-zinc-200/80 bg-white p-6 shadow-[var(--shadow-card)] sm:my-5 sm:p-8">
<%= form_with url: folder_documents_path(folder),
      class: "block",
      html: { multipart: true },
      data: {
        controller: "upload-loading",
        action: "turbo:submit-start->upload-loading#show turbo:submit-end->upload-loading#hide"
      } do %>
  <%= hidden_field_tag :upload_context, upload_context %>

  <div class="space-y-5" data-controller="file-drop">
    <h3 class="text-base font-semibold text-slate-800 sm:text-[1.05rem]">Anexar documentos</h3>

    <%= label_tag dom_id(folder, :document_file), "Selecionar arquivo para enviar", class: "sr-only" %>

    <div
      class="flex min-h-[14rem] cursor-pointer flex-col items-center justify-center rounded-lg border-2 border-dashed border-zinc-300 bg-white px-8 py-12 transition-[border-color,box-shadow] duration-200 sm:min-h-[16rem] sm:px-10 sm:py-14"
      data-file-drop-target="zone"
      data-action="dragenter->file-drop#dragEnter dragover->file-drop#dragOver dragleave->file-drop#dragLeave drop->file-drop#drop click->file-drop#zoneClick"
    >
      <%= file_field_tag "document[file]",
            class: "sr-only",
            id: dom_id(folder, :document_file),
            data: {
              file_drop_target: "input",
              action: "change->file-drop#changed"
            } %>

      <div class="flex w-full max-w-md flex-col items-center text-center">
        <div data-file-drop-target="hint" class="flex w-full flex-col items-center gap-3">
          <div class="text-slate-400" aria-hidden="true">
            <svg class="h-11 w-11 sm:h-12 sm:w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
            </svg>
          </div>

          <p class="text-[0.95rem] font-bold tracking-tight text-slate-800 sm:text-base">
            Arraste e solte aqui
          </p>

        </div>

        <p data-file-drop-target="fileName" class="mt-4 hidden max-w-full break-words text-sm font-medium text-slate-800"></p>
      </div>
    </div>

    <div class="flex flex-col justify-between gap-2 border-t border-zinc-100 pt-4 text-xs leading-relaxed text-zinc-500 sm:flex-row sm:items-center">
      <span>Tipos aceites: PDF, imagens, Office, texto e outros.</span>
      <span class="inline-flex shrink-0 items-center gap-1.5 sm:ml-auto">
        <svg class="h-3.5 w-3.5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 0 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
        </svg>
      </span>
    </div>
  </div>
  <div
    class="fixed inset-0 z-50 hidden items-center justify-center bg-zinc-950/45 backdrop-blur-[1px]"
    data-upload-loading-target="overlay"
    aria-live="polite"
    aria-label="Upload em andamento"
  >
    <div class="mx-4 w-full max-w-sm rounded-xl border border-zinc-200 bg-white p-5 shadow-[var(--shadow-float)]">
      <div class="flex items-center gap-3">
        <svg class="h-5 w-5 animate-spin text-accent" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
          <path class="opacity-90" d="M22 12a10 10 0 0 0-10-10" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
        </svg>
        <div>
          <p class="text-sm font-semibold text-zinc-900">Enviando arquivo...</p>
          <p class="text-xs text-zinc-500">Aguarde, estamos processando o upload.</p>
        </div>
      </div>
    </div>
  </div>
<% end %>
</div>
