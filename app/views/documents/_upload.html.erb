<% upload_context = local_assigns.fetch(:upload_context, "list") %>
<% compact = local_assigns.fetch(:compact, false) %>
<% extra_hidden_fields = local_assigns.fetch(:extra_hidden_fields, {}) %>
<% wrapper_spacing = local_assigns.fetch(:wrapper_spacing, compact ? "my-0 p-5 sm:p-6" : "my-4 p-6 sm:my-5 sm:p-8") %>
<% dropzone_min_height = compact ? "min-h-[11rem] sm:min-h-[12rem] px-6 py-8 sm:px-8 sm:py-10" : "min-h-[14rem] sm:min-h-[16rem] px-8 py-12 sm:px-10 sm:py-14" %>
<% statement_only_mode = local_assigns.fetch(:statement_only_mode, false) %>
<% statement_institutions = local_assigns.fetch(:statement_institutions, []) %>
<% statement_institutions_json = statement_institutions.map { |institution| { id: institution.id, name: institution.name } }.to_json %>

<div class="rounded-xl border border-zinc-200/80 bg-white shadow-[var(--shadow-card)] <%= wrapper_spacing %>">
<%= form_with url: folder_documents_path(folder),
      class: "block",
      html: { multipart: true },
      data: {
        controller: "upload-loading",
        action: "turbo:submit-start->upload-loading#show turbo:submit-end->upload-loading#hide"
      } do %>
  <%= hidden_field_tag :upload_context, upload_context %>
  <% extra_hidden_fields.each do |key, value| %>
    <%= hidden_field_tag key, value %>
  <% end %>

  <div class="space-y-5" data-controller="file-drop <%= "institution-autocomplete" if statement_only_mode %>" <%= %(data-institution-autocomplete-institutions-value="#{ERB::Util.html_escape(statement_institutions_json)}").html_safe if statement_only_mode %>>
    <h3 class="text-base font-semibold text-slate-800 sm:text-[1.05rem]">Anexar documentos</h3>

    <% if statement_only_mode %>
      <div class="grid gap-3 sm:grid-cols-2">
        <div>
          <label class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Tipo de documento</label>
          <select disabled class="mt-1 w-full rounded-md border border-zinc-300 bg-zinc-100 px-3 py-2 text-sm text-zinc-700">
            <option selected>Extrato</option>
          </select>
        </div>
        <div>
          <label for="institution_id_query" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Instituição</label>
          <%= hidden_field_tag :institution_id, params[:institution_id].to_s, required: true, data: { institution_autocomplete_target: "hidden" } %>
          <div class="relative mt-1">
            <input
              type="text"
              id="institution_id_query"
              class="w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-700 placeholder:text-zinc-400 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
              placeholder="Selecione ou pesquise..."
              autocomplete="off"
              autocapitalize="off"
              spellcheck="false"
              role="combobox"
              aria-expanded="false"
              aria-autocomplete="list"
              aria-controls="institution-autocomplete-list"
              data-institution-autocomplete-target="query"
              data-action="focus->institution-autocomplete#open input->institution-autocomplete#search keydown->institution-autocomplete#keydown blur->institution-autocomplete#blur" />
            <ul
              id="institution-autocomplete-list"
              class="hidden absolute left-0 top-full z-40 mt-1 max-h-52 w-full overflow-y-auto rounded-md border border-zinc-200 bg-white py-1 shadow-lg"
              role="listbox"
              data-institution-autocomplete-target="list"
              data-action="mousedown->institution-autocomplete#pick">
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <%= label_tag dom_id(folder, :document_file), "Selecionar arquivo para enviar", class: "sr-only" %>

    <div
      class="flex cursor-pointer flex-col items-center justify-center rounded-lg border-2 border-dashed border-zinc-300 bg-white transition-[border-color,box-shadow] duration-200 <%= dropzone_min_height %>"
      data-file-drop-target="zone"
      data-action="dragenter->file-drop#dragEnter dragover->file-drop#dragOver dragleave->file-drop#dragLeave drop->file-drop#drop click->file-drop#zoneClick"
    >
      <%= file_field_tag "document[file]",
            class: "sr-only",
            id: dom_id(folder, :document_file),
            data: {
              file_drop_target: "input",
              action: "change->file-drop#changed"
            } %>

      <div class="flex w-full max-w-md flex-col items-center text-center">
        <div data-file-drop-target="hint" class="flex w-full flex-col items-center gap-5 sm:gap-6">
          <div class="inline-flex h-[5.5rem] w-[5.5rem] shrink-0 items-center justify-center rounded-full bg-white shadow-md ring-2 ring-teal-200/90 sm:h-28 sm:w-28" aria-hidden="true">
            <%= heroicon "arrow-up-tray", variant: :outline, options: { class: "h-12 w-12 shrink-0 text-accent sm:h-14 sm:w-14", "aria-hidden": "true" } %>
          </div>

          <p class="text-base font-bold tracking-tight text-slate-800 sm:text-lg">
            Arraste e solte aqui
          </p>

        </div>

        <p data-file-drop-target="fileName" class="mt-4 hidden max-w-full break-words text-sm font-medium text-slate-800"></p>
      </div>
    </div>

    <div class="flex flex-col justify-between gap-2 border-t border-zinc-100 pt-4 text-xs leading-relaxed text-zinc-500 sm:flex-row sm:items-center">
      <span>Tipos aceites: PDF, imagens, Office, texto e outros.</span>
    </div>
  </div>
  <div
    class="fixed inset-0 z-50 hidden items-center justify-center bg-zinc-950/45 backdrop-blur-[1px]"
    data-upload-loading-target="overlay"
    aria-live="polite"
    aria-label="Upload em andamento"
  >
    <div class="mx-4 w-full max-w-sm rounded-xl border border-zinc-200 bg-white p-5 shadow-[var(--shadow-float)]">
      <div class="flex items-center gap-3">
        <%= heroicon "arrow-path", variant: :outline, options: { class: "h-5 w-5 shrink-0 animate-spin text-accent", "aria-hidden": "true" } %>
        <div>
          <p class="text-sm font-semibold text-zinc-900">Enviando arquivo...</p>
          <p class="text-xs text-zinc-500">Aguarde, estamos processando o upload.</p>
        </div>
      </div>
    </div>
  </div>
<% end %>
</div>
