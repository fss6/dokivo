<% content_for :title, "Timeline · Dokivo" %>

<div class="space-y-6">
  <header class="space-y-2">
    <p class="text-xs font-semibold uppercase tracking-wide text-accent">Visao cronologica por cliente</p>
    <h1 class="text-2xl font-semibold text-zinc-900 sm:text-3xl">Timeline</h1>
    <p class="text-sm text-zinc-600">
      Cliente ativo: <strong><%= current_client.name %></strong>.
      Competencia: <strong><%= l(@period, format: "%m/%Y") %></strong>.
    </p>
  </header>

  <section class="app-card p-4 sm:p-5">
    <%= form_with url: timeline_path, method: :get, local: true, class: "flex flex-wrap items-end gap-3" do %>
      <div>
        <label for="timeline_period" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Competencia</label>
        <input id="timeline_period" name="period" type="month" value="<%= @period_param %>" class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm text-zinc-800">
      </div>
      <button type="submit" class="app-btn-primary">Atualizar timeline</button>
    <% end %>
  </section>

  <section class="grid grid-cols-1 gap-4 md:grid-cols-4">
    <article class="app-card p-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Completude</p>
      <p class="mt-2 text-3xl font-semibold tracking-tight text-zinc-900"><%= @kpis[:progress_percent] %>%</p>
      <div class="mt-2 h-2 rounded-full bg-zinc-200">
        <div class="h-2 rounded-full bg-amber-500 transition-all" style="width: <%= @kpis[:progress_percent] %>%"></div>
      </div>
    </article>
    <article class="app-card p-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Recebidos</p>
      <p class="mt-2 text-3xl font-semibold tracking-tight text-emerald-600"><%= @kpis[:received_count] %></p>
    </article>
    <article class="app-card p-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Pendentes</p>
      <p class="mt-2 text-3xl font-semibold tracking-tight text-red-600"><%= @kpis[:pending_count] %></p>
    </article>
    <article class="app-card p-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Itens do mes</p>
      <p class="mt-2 text-3xl font-semibold tracking-tight text-zinc-900"><%= @kpis[:total_count] %></p>
    </article>
  </section>

  <section class="app-card p-4 sm:p-6">
    <% if @timeline_days.any? %>
      <ol class="relative ml-5 border-l border-zinc-200">
        <% @timeline_days.each do |day| %>
          <li class="mb-6 ml-6 last:mb-0">
            <span class="absolute -left-2 mt-2 h-4 w-4 rounded-full border border-zinc-200 bg-white"></span>
            <div class="mb-2 flex items-center gap-2">
              <p class="text-sm font-semibold uppercase tracking-wide <%= day[:kind] == :missing ? "text-red-500" : "text-zinc-500" %>">
                <%= day[:label] %>
              </p>
              <% if day[:kind] == :missing %>
                <span class="rounded-full border border-red-200 bg-red-50 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-red-600">falta</span>
              <% end %>
            </div>

            <div class="space-y-2">
              <% day[:events].each do |event| %>
                <% card_classes = if event[:kind] == :missing_item
                  "rounded-xl border border-dashed border-red-300 bg-red-50/50 p-4"
                else
                  "rounded-xl border border-zinc-200 bg-white p-4"
                end %>
                <article class="<%= card_classes %>">
                  <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                      <p class="text-base font-semibold <%= event[:kind] == :missing_item ? "text-red-600" : "text-zinc-900" %>">
                        <%= event[:title] %>
                      </p>
                      <p class="mt-1 text-sm <%= event[:kind] == :missing_item ? "text-red-500" : "text-zinc-500" %>">
                        <%= event[:subtitle] %>
                      </p>
                    </div>
                    <span class="shrink-0 rounded-full px-2.5 py-1 text-xs font-semibold <%= event[:kind] == :missing_item ? "bg-red-100 text-red-600" : "bg-emerald-100 text-emerald-700" %>">
                      <%= event[:badge] %>
                    </span>
                  </div>
                  <div class="mt-3 flex justify-end">
                    <%= link_to event[:cta_label], event[:cta_path], class: (event[:kind] == :missing_item ? "app-btn-primary" : "app-btn-secondary"), data: { turbo: false } %>
                  </div>
                </article>
              <% end %>
            </div>
          </li>
        <% end %>
      </ol>
    <% else %>
      <div class="rounded-xl border border-zinc-200 bg-zinc-50 px-4 py-8 text-center text-sm text-zinc-600">
        Nenhum documento ou pendencia encontrado para esta competencia.
      </div>
    <% end %>
  </section>
</div>
