<% content_for :title, "Editar integração · Dokivo" %>

<div class="mx-auto max-w-xl space-y-6">
  <header>
    <%= link_to "← Voltar", account_integration_connections_path(@account), class: "text-sm font-medium text-accent" %>
    <h1 class="mt-3 text-2xl font-semibold tracking-tight text-zinc-900">Editar integração</h1>
  </header>

  <section class="app-card p-5">
    <%= render "form" %>
  </section>

  <div class="flex flex-wrap gap-2">
    <%= button_to "Testar conexão com a Meta",
                  test_connection_account_integration_connection_path(@account, @connection),
                  method: :post,
                  class: "rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-900" %>
  </div>
</div>
