<tr class="transition-colors hover:bg-zinc-50/80">
  <td class="px-4 py-3">
    <%= link_to folder.name, folder, class: "font-medium text-zinc-900 no-underline hover:text-accent" %>
  </td>
  <td class="hidden px-4 py-3 text-sm text-zinc-600 sm:table-cell">
    <% if folder.account %>
      <%= link_to folder.account.name, account_path(folder.account), class: "text-zinc-600 no-underline hover:text-accent" %>
    <% else %>
      —
    <% end %>
  </td>
  <td class="px-4 py-3 text-right">
    <div class="flex flex-wrap items-center justify-end gap-2">
      <%= link_to folder,
            class: "app-btn-secondary inline-flex items-center justify-center px-2.5 py-1.5 text-xs",
            title: "Ver pasta",
            aria: { label: "Ver pasta" } do %>
        <%= heroicon "eye", variant: :outline, options: { class: "h-4 w-4", "aria-hidden": "true" } %>
      <% end %>
      <%= link_to "Documentos", folder_documents_path(folder), class: "app-btn-secondary px-3 py-1.5 text-xs" %>
      <%= link_to edit_folder_path(folder),
            class: "app-btn-secondary inline-flex items-center justify-center px-2.5 py-1.5 text-xs",
            title: "Editar pasta",
            aria: { label: "Editar pasta" } do %>
        <%= heroicon "pencil-square", variant: :outline, options: { class: "h-4 w-4", "aria-hidden": "true" } %>
      <% end %>
      <%= button_tag type: "button",
            class: "app-btn-danger inline-flex items-center justify-center cursor-pointer px-2.5 py-1.5 text-xs",
            title: "Excluir pasta",
            aria: { label: "Excluir pasta" },
            data: app_confirm_modal_open_data(url: folder_path(folder), item_label: folder.name) do %>
        <%= heroicon "trash", variant: :outline, options: { class: "h-4 w-4", "aria-hidden": "true" } %>
      <% end %>
    </div>
  </td>
</tr>
