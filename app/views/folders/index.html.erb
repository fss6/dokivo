<% content_for :title, "Pastas · Dokivo" %>

<div
  class="space-y-8"
  data-controller="folder-explorer app-confirm-modal"
  data-folder-explorer-selected-folder-id-value="<%= @selected_folder&.id %>"
>
  <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-accent">Organização</p>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Pastas</h1>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-zinc-600">
        Agrupe documentos por cliente com pastas nomeadas. Use o seletor de cliente no topo para filtrar o que você vê.
      </p>
    </div>
    <%= link_to "Nova pasta", new_folder_path, class: "app-btn-primary w-full shrink-0 sm:w-auto" %>
  </header>

  <% if @folders.any? %>
    <div class="grid grid-cols-1 gap-4 xl:grid-cols-12">
      <aside class="app-card p-3 xl:col-span-3">
        <p class="px-2 pb-2 text-xs font-semibold uppercase tracking-wide text-zinc-500">Pastas</p>
        <nav class="space-y-1">
          <% @folders.each do |folder| %>
            <% active = @selected_folder&.id == folder.id %>
            <%= link_to folders_path(folder_id: folder.id), class: [
                  "flex items-center justify-between rounded-md px-3 py-2 text-sm no-underline transition-colors",
                  (active ? "bg-zinc-900 text-white" : "text-zinc-700 hover:bg-zinc-100")
                ].join(" "),
                data: {
                  folder_explorer_target: "folder",
                  folder_id: folder.id,
                  action: "dragover->folder-explorer#dragOver dragenter->folder-explorer#dragEnter dragleave->folder-explorer#dragLeave drop->folder-explorer#drop"
                } do %>
              <span class="font-medium"><%= folder.name %></span>
              <span class="<%= active ? 'text-zinc-300' : 'text-zinc-500' %> text-xs">
                <%= folder.try(:documents_count).to_i %>
              </span>
            <% end %>
          <% end %>
        </nav>
      </aside>

      <section class="app-card overflow-hidden xl:col-span-9">
        <header class="flex items-center justify-between border-b border-zinc-100 px-4 py-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Arquivos da pasta</p>
            <h2 class="text-lg font-semibold text-zinc-900"><%= @selected_folder&.name || "Sem pasta selecionada" %></h2>
          </div>
          <% if @selected_folder %>
            <%= link_to folder_path(@selected_folder),
                  class: "app-btn-secondary inline-flex items-center gap-1.5 px-3 py-1.5 text-xs no-underline" do %>
              <%= heroicon "folder", variant: :outline, options: { class: "h-4 w-4 shrink-0", "aria-hidden": "true" } %>
              <span>Detalhes da pasta</span>
            <% end %>
          <% end %>
        </header>

        <% if @documents.any? %>
          <div class="overflow-x-auto">
            <table class="min-w-full text-left text-sm">
              <thead>
                <tr class="border-b border-zinc-200 bg-zinc-50/90 text-xs font-semibold uppercase tracking-wide text-zinc-500">
                  <th class="px-4 py-3 font-semibold">Arquivo</th>
                  <th class="hidden px-4 py-3 font-semibold sm:table-cell">Usuário</th>
                  <th class="px-4 py-3 font-semibold">Status</th>
                  <th class="px-4 py-3 text-right font-semibold">Ações</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-zinc-100">
                <%= render partial: "documents/document_row",
                      collection: @documents,
                      as: :document,
                      locals: {
                        in_folder: true,
                        folder_explorer: true
                      } %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="px-6 py-12 text-center">
            <p class="text-sm font-medium text-zinc-900">Nenhum documento nesta pasta</p>
            <p class="mt-1 text-sm text-zinc-500">Use a tela da pasta para enviar arquivos ou mova documentos para cá.</p>
          </div>
        <% end %>
      </section>
    </div>
  <% else %>
    <div class="app-card px-6 py-16 text-center">
      <p class="text-sm font-medium text-zinc-900">Nenhuma pasta cadastrada</p>
      <p class="mt-1 text-sm text-zinc-500">Crie a primeira pasta para organizar seus ativos.</p>
      <%= link_to "Nova pasta", new_folder_path, class: "app-btn-primary mt-6 inline-flex" %>
    </div>
  <% end %>

  <%= render "documents/confirm_modal" %>
</div>
