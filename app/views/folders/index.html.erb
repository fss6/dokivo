<% content_for :title, "Pastas · Dokivo" %>

<div
  class="space-y-8"
  data-controller="folder-explorer"
  data-folder-explorer-selected-folder-id-value="<%= @selected_folder&.id %>"
>
  <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-accent">Explorador</p>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Pastas</h1>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-zinc-600">
        Organize seus documentos por pastas para facilitar o dia a dia.
      </p>
    </div>
    <%= link_to "Nova pasta", new_folder_path, class: "app-btn-primary w-full shrink-0 sm:w-auto" %>
  </header>

  <% if @folders.any? %>
    <section class="overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm">
      <header class="border-b border-zinc-200 bg-zinc-50/80 px-4 py-3">
        <div class="flex flex-wrap items-center gap-3">
          <div class="flex items-center gap-1.5">
            <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
          </div>
          <div class="inline-flex items-center gap-2 rounded-md border border-zinc-200 bg-white px-3 py-1.5 text-xs font-medium text-zinc-600">
            <%= heroicon "folder-open", variant: :solid, options: { class: "h-4 w-4 text-zinc-500", "aria-hidden": "true" } %>
            <span><%= current_client&.name.presence || "Todos os clientes" %></span>
            <span class="text-zinc-400">/</span>
            <span class="text-zinc-900">Pastas</span>
          </div>
        </div>
      </header>

      <div class="bg-zinc-50/40 p-4">
        <p class="px-2 pb-3 text-xs font-semibold uppercase tracking-wide text-zinc-500">Pastas</p>
        <nav class="grid grid-cols-2 gap-4 sm:grid-cols-3 xl:grid-cols-5">
          <% @folders.each do |folder| %>
            <% active = @selected_folder&.id == folder.id %>
            <%= button_tag type: "button",
                class: [
                  "group flex w-full flex-col items-center justify-center rounded-xl px-2 py-3 text-center text-sm transition-colors",
                  (active ? "bg-amber-100/70 text-amber-900 shadow-sm" : "text-zinc-700 hover:bg-zinc-100/80")
                ].join(" "),
                data: {
                  folder_explorer_target: "folder",
                  folder_id: folder.id,
                  folder_url: folder_path(folder),
                  active_classes: "bg-amber-100/70 text-amber-900 shadow-sm",
                  inactive_classes: "text-zinc-700 hover:bg-zinc-100/80",
                  action: "click->folder-explorer#selectFolder dblclick->folder-explorer#openFolder dragover->folder-explorer#dragOver dragenter->folder-explorer#dragEnter dragleave->folder-explorer#dragLeave drop->folder-explorer#drop"
                },
                title: "Dê dois cliques para abrir a pasta",
                aria: { current: (active ? "true" : nil) } do %>
              <% documents_count = folder.try(:documents_count).to_i %>
              <% badge_label = documents_count > 99 ? "99+" : documents_count.to_s %>
              <span class="relative inline-flex">
                <%= heroicon "folder", variant: :solid, options: { class: "h-14 w-14 text-amber-400 drop-shadow-sm", "aria-hidden": "true" } %>
                <% if documents_count.positive? %>
                  <span class="absolute -right-3 -top-1 inline-flex min-w-7 items-center justify-center rounded-full bg-blue-500 px-1.5 py-0.5 text-[11px] font-bold leading-none text-white shadow-sm">
                    <%= badge_label %>
                  </span>
                <% end %>
              </span>
              <span class="mt-2 line-clamp-2 min-h-[2.5rem] text-sm font-medium leading-tight"><%= folder.name %></span>
            <% end %>
          <% end %>
        </nav>
      </div>
    </section>
  <% else %>
    <div class="app-card px-6 py-16 text-center">
      <p class="text-sm font-medium text-zinc-900">Nenhuma pasta cadastrada</p>
      <p class="mt-1 text-sm text-zinc-500">Crie a primeira pasta para organizar seus ativos.</p>
      <%= link_to "Nova pasta", new_folder_path, class: "app-btn-primary mt-6 inline-flex" %>
    </div>
  <% end %>
</div>
