<% content_for :title, "Pastas · Docfy" %>

<div class="space-y-8">
  <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-accent">Organização</p>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Pastas</h1>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-zinc-600">
        Agrupe conteúdo por conta com pastas nomeadas.
      </p>
    </div>
    <%= link_to "Nova pasta", new_folder_path, class: "app-btn-primary w-full shrink-0 sm:w-auto" %>
  </header>

  <% if @folders.any? %>
    <div class="px-1 py-2 sm:px-2">
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
      <%= render partial: "folders/folder_card", collection: @folders, as: :folder %>
      </div>
    </div>
  <% else %>
    <div class="app-card px-6 py-16 text-center">
      <p class="text-sm font-medium text-zinc-900">Nenhuma pasta cadastrada</p>
      <p class="mt-1 text-sm text-zinc-500">Crie a primeira pasta para organizar seus ativos.</p>
      <%= link_to "Nova pasta", new_folder_path, class: "app-btn-primary mt-6 inline-flex" %>
    </div>
  <% end %>
</div>
