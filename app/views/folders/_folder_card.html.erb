<article class="app-card app-card-hover h-full overflow-hidden bg-white">
  <%= link_to folder_path(folder), class: "block p-6 no-underline sm:p-7" do %>
    <div class="flex items-start justify-between gap-4">
      <div class="flex min-w-0 items-center gap-3 text-zinc-900 transition-colors hover:text-accent">
        <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-teal-50 ring-1 ring-teal-100">
          <%= heroicon "folder", variant: :outline, options: { class: "h-5 w-5 shrink-0 text-accent", "aria-hidden": "true" } %>
        </span>
        <span class="min-w-0">
          <span class="block truncate text-base font-semibold"><%= folder.name %></span>
          <span class="block truncate text-sm text-zinc-500">
            <%= folder.try(:documents_count).to_i %> arquivo(s)
          </span>
        </span>
      </div>
    </div>
    <div class="mt-4 border-t border-zinc-100 pt-4 text-sm text-zinc-500">
      Acessar pasta e documentos
    </div>
  <% end %>
</article>
