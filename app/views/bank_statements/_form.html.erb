<%= form_with(model: bank_statement, class: "space-y-6") do |form| %>
  <% if bank_statement.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900 shadow-[var(--shadow-card)]" role="alert">
      <p class="font-medium">Revise os campos para continuar:</p>
      <ul class="mt-2 list-inside list-disc space-y-0.5 text-red-800">
        <% bank_statement.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-5 sm:grid-cols-2">
    <div class="sm:col-span-2">
      <%= form.label :bank_statement_import_id, "Importação de origem", class: "app-label" %>
      <%= form.select :bank_statement_import_id,
            options_for_select(@import_options, bank_statement.bank_statement_import_id),
            { include_blank: "Selecionar import..." },
            class: "app-input",
            required: true %>
      <p class="mt-1 text-xs text-zinc-500">A instituição será definida automaticamente com base no import.</p>
    </div>
    <div>
      <%= form.label :occurred_on, "Data", class: "app-label" %>
      <%= form.date_field :occurred_on, class: "app-input", required: true %>
    </div>
    <div>
      <%= form.label :transaction_type, "Tipo", class: "app-label" %>
      <%= form.select :transaction_type,
            options_for_select([
              [bank_statement_transaction_type_label("credit"), "credit"],
              [bank_statement_transaction_type_label("debit"), "debit"]
            ], bank_statement.transaction_type),
            {},
            class: "app-input",
            required: true %>
    </div>
    <div class="sm:col-span-2">
      <%= form.label :description, "Descrição", class: "app-label" %>
      <%= form.text_field :description, class: "app-input", required: true, autocomplete: "off" %>
    </div>
    <div data-controller="currency-input">
      <%= form.label :amount, "Valor", class: "app-label" %>
      <%= form.hidden_field :amount, required: true, data: { currency_input_target: "hidden" } %>
      <input
        type="text"
        class="app-input"
        placeholder="R$ 0,00"
        inputmode="decimal"
        autocomplete="off"
        data-currency-input-target="display"
        data-action="focus->currency-input#onFocus input->currency-input#onInput blur->currency-input#onBlur"
        value="<%= bank_statement.amount.present? ? number_to_currency(bank_statement.amount, locale: :'pt-BR') : '' %>" />
      <p class="mt-1 text-xs text-zinc-500">Aceita valores positivos e negativos.</p>
    </div>
    <% if bank_statement.persisted? && bank_statement.possible_duplicate? %>
      <div class="sm:col-span-2">
        <label class="flex items-start gap-3 rounded-md border border-zinc-200 bg-zinc-50/70 px-3 py-2.5">
          <%= form.check_box :possible_duplicate, class: "mt-0.5 h-4 w-4 rounded border-zinc-300 text-accent focus:ring-accent/30" %>
          <span>
            <span class="block text-sm font-medium text-zinc-800">Possível duplicata</span>
            <span class="mt-0.5 block text-xs text-zinc-600">Desmarque para resolver e seguir com este lançamento como válido.</span>
          </span>
        </label>
      </div>
    <% end %>
  </div>

  <div class="flex flex-col-reverse gap-3 border-t border-zinc-100 pt-6 sm:flex-row sm:justify-end">
    <%= link_to "Cancelar", bank_statements_path, class: "app-btn-secondary text-center sm:text-left" %>
    <%= form.submit bank_statement.persisted? ? "Atualizar lançamento" : "Criar lançamento", class: "app-btn-primary cursor-pointer border-0" %>
  </div>
<% end %>
