<% content_for :title, "Extratos · #{current_client.name} · Dokivo" %>

<div class="space-y-4" data-controller="app-confirm-modal">
  <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <nav class="text-xs font-medium text-zinc-500" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li><%= link_to "Clientes", clients_path, class: "text-zinc-500 no-underline hover:text-accent" %></li>
          <li aria-hidden="true">/</li>
          <li><%= link_to current_client.name, current_client, class: "text-zinc-500 no-underline hover:text-accent" %></li>
          <li aria-hidden="true">/</li>
          <li class="text-zinc-700">Extratos</li>
        </ol>
      </nav>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Extratos e lançamentos</h1>
    </div>
    <div class="flex items-center gap-2">
      <% if policy(BankStatement).create? %>
        <%= link_to "Novo lançamento", new_bank_statement_path, class: "app-btn-primary no-underline" %>
      <% end %>
    </div>
  </header>

  <section class="min-w-0" aria-labelledby="launches-heading">
    <div class="grid gap-3 sm:grid-cols-3 mb-3">
      <article class="app-card p-4">
        <p class="text-[11px] font-semibold uppercase tracking-wide text-zinc-500">Total entradas</p>
        <p class="mt-1 text-xl font-semibold text-emerald-700"><%= bank_statement_amount_currency(@total_entries) %></p>
      </article>
      <article class="app-card p-4">
        <p class="text-[11px] font-semibold uppercase tracking-wide text-zinc-500">Total saídas</p>
        <p class="mt-1 text-xl font-semibold text-red-600"><%= bank_statement_amount_currency(@total_exits) %></p>
      </article>
      <article class="app-card p-4">
        <p class="text-[11px] font-semibold uppercase tracking-wide text-zinc-500">Saldo final</p>
        <p class="mt-1 text-xl font-semibold <%= @final_balance.negative? ? 'text-red-600' : 'text-emerald-700' %>"><%= bank_statement_amount_currency(@final_balance) %></p>
      </article>
    </div>

    <% active_filters_count = [params[:institution_id], params[:transaction_type], params[:occurred_from], params[:occurred_to]].count(&:present?) %>
    <details class="app-card mb-3 group" <%= "open" if active_filters_count.positive? %>>
      <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3 text-left [&::-webkit-details-marker]:hidden">
        <div class="flex items-center gap-2">
          <span id="launches-heading" class="text-sm font-semibold text-zinc-900">Filtros</span>
          <span class="text-xs text-zinc-500">Clique para expandir</span>
          <% if active_filters_count.positive? %>
            <span class="inline-flex items-center rounded bg-accent/10 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-accent"><%= active_filters_count %> ativo(s)</span>
          <% end %>
        </div>
        <svg class="h-4 w-4 shrink-0 text-zinc-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
      </summary>
      <div class="border-t border-zinc-100 px-4 py-4">
        <%= form_with url: bank_statements_path, method: :get do %>
          <% if params[:import_id].present? %>
            <%= hidden_field_tag :import_id, params[:import_id] %>
          <% end %>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
            <div class="sm:col-span-2 lg:col-span-2">
              <%= label_tag :institution_id, "Instituição", class: "app-label" %>
              <%= select_tag :institution_id,
                    options_for_select([["Todas", ""]] + @institution_filter_options, params[:institution_id]),
                    class: "app-input" %>
            </div>
            <div>
              <%= label_tag :transaction_type, "Tipo", class: "app-label" %>
              <%= select_tag :transaction_type,
                    options_for_select([["Todos", ""]] + @transaction_type_filter_options, params[:transaction_type]),
                    class: "app-input" %>
            </div>
            <div>
              <%= label_tag :occurred_from, "Data inicial", class: "app-label" %>
              <%= date_field_tag :occurred_from, params[:occurred_from], class: "app-input" %>
            </div>
            <div>
              <%= label_tag :occurred_to, "Data final", class: "app-label" %>
              <%= date_field_tag :occurred_to, params[:occurred_to], class: "app-input" %>
            </div>
          </div>
          <div class="mt-3 flex items-center justify-end gap-2">
            <%= link_to "Limpar", bank_statements_path(import_id: params[:import_id].presence), class: "app-btn-secondary no-underline" %>
            <%= submit_tag "Filtrar", class: "app-btn-primary cursor-pointer border-0" %>
          </div>
        <% end %>
      </div>
    </details>

    <% if @bank_statements.any? %>
      <div class="app-card overflow-hidden">
        <div class="overflow-x-auto px-3 pb-4 pt-3 sm:px-4">
          <table class="min-w-full text-left text-sm">
            <thead>
              <tr class="border-b border-zinc-100 bg-zinc-50/80 text-xs font-semibold uppercase tracking-wide text-zinc-500">
                <th class="px-4 py-3 font-semibold sm:px-5">Data</th>
                <th class="px-4 py-3 font-semibold sm:px-5">Instituição</th>
                <th class="px-4 py-3 font-semibold sm:px-5">Descrição</th>
                <th class="px-4 py-3 font-semibold sm:px-5">Tipo</th>
                <th class="px-4 py-3 text-right font-semibold sm:px-5">Valor</th>
                <th class="px-4 py-3 text-right font-semibold sm:px-5">Ações</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-100">
              <% @bank_statements.each do |row| %>
                <tr class="bg-white">
                  <td class="whitespace-nowrap px-4 py-3 text-zinc-800 sm:px-5"><%= row.occurred_on.strftime("%d/%m/%Y") %></td>
                  <td class="max-w-[14rem] truncate px-4 py-3 text-zinc-700 sm:px-5" title="<%= row.institution&.name %>"><%= row.institution&.name.presence || "—" %></td>
                  <td class="max-w-md px-4 py-3 text-zinc-700 sm:px-5">
                    <%= row.description %>
                    <% if row.possible_duplicate? %>
                      <span class="ml-2 inline-flex items-center rounded bg-amber-100 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-amber-800">Duplicata?</span>
                    <% end %>
                  </td>
                  <td class="px-4 py-3 text-zinc-600 sm:px-5"><%= bank_statement_transaction_type_label(row.transaction_type) %></td>
                  <td class="whitespace-nowrap px-4 py-3 text-right font-medium tabular-nums sm:px-5 <%= bank_statement_amount_text_class(row) %>">
                    <%= bank_statement_amount_currency(row.amount) %>
                  </td>
                  <td class="whitespace-nowrap px-4 py-3 text-right sm:px-5">
                    <div class="inline-flex items-center gap-2">
                      <% imp = row.bank_statement_import %>
                      <% if imp.file.attached? %>
                        <%= link_to original_bank_statement_import_path(imp),
                              class: "inline-flex text-zinc-500 hover:text-zinc-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-zinc-300 rounded",
                              target: "_blank",
                              rel: "noopener",
                              title: "Abrir PDF original (import ##{imp.id})",
                              aria: { label: "Abrir PDF original do import ##{imp.id}" } do %>
                          <%= heroicon "document-text", variant: :outline, options: { class: "h-5 w-5 shrink-0", "aria-hidden": "true" } %>
                        <% end %>
                      <% else %>
                        <%= link_to bank_statement_import_path(imp),
                              class: "inline-flex text-zinc-400 hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/40 rounded",
                              title: "Import ##{imp.id} (PDF indisponível)",
                              aria: { label: "Ver importação ##{imp.id}, PDF indisponível" } do %>
                          <%= heroicon "document-text", variant: :outline, options: { class: "h-5 w-5 shrink-0 opacity-70", "aria-hidden": "true" } %>
                        <% end %>
                      <% end %>
                      <% if policy(row).update? %>
                        <%= link_to edit_bank_statement_path(row),
                              class: "inline-flex text-accent hover:text-accent/80 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/40 rounded",
                              title: "Editar lançamento",
                              aria: { label: "Editar lançamento ##{row.id}" } do %>
                          <%= heroicon "pencil-square", variant: :outline, options: { class: "h-5 w-5 shrink-0", "aria-hidden": "true" } %>
                        <% end %>
                      <% end %>
                      <% if policy(row).destroy? %>
                        <%= button_tag type: "button",
                              class: "inline-flex cursor-pointer border-0 bg-transparent p-0 text-red-600 hover:text-red-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-300 rounded",
                              title: "Excluir lançamento",
                              aria: { label: "Excluir lançamento ##{row.id}" },
                              data: app_confirm_modal_open_data(
                                url: bank_statement_path(row),
                                item_label: row.description.to_s.truncate(42),
                                heading: "Excluir lançamento",
                                body_prefix: "Confirma a exclusão de ",
                                body_suffix: "? Esta ação não pode ser desfeita.",
                                confirm_text: "Excluir lançamento",
                                confirm_variant: "danger"
                              ) do %>
                          <%= heroicon "trash", variant: :outline, options: { class: "h-5 w-5 shrink-0", "aria-hidden": "true" } %>
                        <% end %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
      <% if @pagy.pages > 1 %>
        <div class="mt-3 flex justify-end">
          <%== @pagy.series_nav %>
        </div>
      <% end %>
    <% else %>
      <div class="app-card p-8 text-center text-sm text-zinc-600">
        <p>Nenhum lançamento ainda.</p>
      </div>
    <% end %>
  </section>

  <%= render "shared/confirm_modal",
        heading: "Excluir lançamento",
        body_prefix: "Confirma a exclusão de ",
        body_suffix: "? Esta ação não pode ser desfeita.",
        confirm_text: "Excluir lançamento" %>
</div>
