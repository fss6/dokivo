<% content_for :title, "Extratos · #{current_client.name} · Dokivo" %>

<div class="space-y-8">
  <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <nav class="text-xs font-medium text-zinc-500" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li><%= link_to "Clientes", clients_path, class: "text-zinc-500 no-underline hover:text-accent" %></li>
          <li aria-hidden="true">/</li>
          <li><%= link_to current_client.name, current_client, class: "text-zinc-500 no-underline hover:text-accent" %></li>
          <li aria-hidden="true">/</li>
          <li class="text-zinc-700">Extratos</li>
        </ol>
      </nav>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Extratos e lançamentos</h1>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-zinc-600">
        Importe PDFs (OCR Mistral + extração OpenAI). Os lançamentos ficam em <span class="font-medium text-zinc-700">abas por instituição</span>.
        <% if params[:import_id].present? %>
          <%= link_to "Ver todos os lançamentos", bank_statements_path, class: "font-medium text-accent no-underline hover:underline" %>
          (filtro: <%= link_to "import ##{params[:import_id]}", bank_statement_import_path(params[:import_id]), class: "font-medium text-accent no-underline hover:underline" %>).
        <% end %>
      </p>
    </div>
  </header>

  <% show_import_column = policy(BankStatementImport).create? || @recent_imports.any? %>
  <div class="<%= show_import_column ? "grid gap-8 lg:grid-cols-[minmax(0,22rem)_minmax(0,1fr)] lg:items-start" : "" %>">
    <% if show_import_column %>
      <div class="space-y-6 lg:min-w-0">
        <% if policy(BankStatementImport).create? %>
          <section class="app-card p-6 sm:p-8" aria-labelledby="import-heading">
            <h2 id="import-heading" class="text-sm font-semibold text-zinc-900">Importar extrato (PDF)</h2>
            <p class="mt-1 text-sm text-zinc-600">Apenas ficheiros PDF. O processamento corre em segundo plano.</p>
            <%= form_with model: @bank_statement_import, url: bank_statements_path, method: :post, class: "mt-4 space-y-4", multipart: true do |form| %>
              <% if @bank_statement_import.errors.any? %>
                <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900" role="alert">
                  <ul class="list-inside list-disc">
                    <% @bank_statement_import.errors.each do |error| %>
                      <li><%= error.full_message %></li>
                    <% end %>
                  </ul>
                </div>
              <% end %>
              <div>
                <%= form.label :institution_id, "Instituição do extrato", class: "app-label" %>
                <%= form.collection_select :institution_id,
                      @institutions,
                      :id,
                      :name,
                      { prompt: "Seleccione…" },
                      class: "app-input", required: true %>
                <p class="mt-1 text-xs text-zinc-500">
                  <%= link_to "Gerir instituições", institutions_path, class: "text-accent no-underline hover:underline" %>
                </p>
              </div>
              <div>
                <%= form.label :file, "Ficheiro PDF", class: "app-label" %>
                <%= form.file_field :file, accept: "application/pdf", class: "app-input", required: true %>
              </div>
              <div class="flex justify-end border-t border-zinc-100 pt-4">
                <%= form.submit "Enviar e processar", class: "app-btn-primary cursor-pointer border-0" %>
              </div>
            <% end %>
          </section>
        <% end %>

        <% if @recent_imports.any? %>
          <details class="app-card overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm group">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3 text-left [&::-webkit-details-marker]:hidden">
              <div>
                <span class="text-sm font-medium text-zinc-900">Histórico de importações</span>
                <span class="ml-2 text-xs font-normal text-zinc-500">(últimos <%= @recent_imports.size %>)</span>
              </div>
              <svg class="h-4 w-4 shrink-0 text-zinc-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>
            <div class="border-t border-zinc-100 bg-zinc-50/60 px-3 py-2">
              <p class="px-1 pb-2 text-[11px] uppercase tracking-wide text-zinc-500">Log</p>
              <div class="max-h-64 overflow-y-auto rounded-md border border-zinc-200/80 bg-white">
                <table class="min-w-full text-left text-xs text-zinc-700">
                  <thead class="sticky top-0 border-b border-zinc-200 bg-zinc-100/90 text-[10px] font-semibold uppercase tracking-wide text-zinc-500">
                    <tr>
                      <th class="whitespace-nowrap px-2 py-1.5 font-semibold">Quando</th>
                      <th class="hidden px-2 py-1.5 font-semibold sm:table-cell">Inst.</th>
                      <th class="px-2 py-1.5 font-semibold">Estado</th>
                      <th class="hidden px-2 py-1.5 font-semibold md:table-cell">#</th>
                      <th class="px-2 py-1.5 font-semibold"></th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-zinc-100 font-mono tabular-nums">
                    <% @recent_imports.each do |imp| %>
                      <tr class="bg-white hover:bg-zinc-50/80">
                        <td class="whitespace-nowrap px-2 py-1.5 text-zinc-600"><%= imp.created_at.strftime("%d/%m/%Y %H:%M") %></td>
                        <td class="hidden max-w-[6rem] truncate px-2 py-1.5 text-zinc-500 sm:table-cell" title="<%= imp.institution&.name %>"><%= imp.institution&.name&.truncate(12) || "—" %></td>
                        <td class="px-2 py-1.5">
                          <span class="inline-block rounded px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide
                            <%= case imp.status
                                when "completed" then "bg-emerald-100 text-emerald-800"
                                when "failed" then "bg-red-100 text-red-800"
                                when "processing", "pending" then "bg-amber-100 text-amber-900"
                                else "bg-zinc-100 text-zinc-600"
                                end %>">
                            <%= imp.status %>
                          </span>
                        </td>
                        <td class="hidden px-2 py-1.5 text-zinc-500 md:table-cell"><%= imp.bank_statements.size %></td>
                        <td class="px-2 py-1.5 text-right font-sans">
                          <%= link_to "abrir", bank_statement_import_path(imp), class: "text-accent no-underline hover:underline" %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
          </details>
        <% end %>
      </div>
    <% end %>

    <section class="min-w-0" aria-labelledby="launches-heading">
      <h2 id="launches-heading" class="mb-3 text-sm font-semibold text-zinc-900">Lançamentos por instituição</h2>

      <% if @institution_tabs.any? %>
        <div class="app-card overflow-hidden" data-controller="institution-tabs">
          <div
            class="flex gap-0 overflow-x-auto border-b border-zinc-200 bg-zinc-50/80 px-2 pt-2"
            role="tablist"
            aria-label="Instituições">
            <% @institution_tabs.each_with_index do |(institution, rows), idx| %>
              <button
                type="button"
                id="inst-tab-<%= idx %>"
                role="tab"
                class="-mb-px shrink-0 rounded-t-md border-b-2 border-transparent px-3 py-2 text-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/40"
                data-institution-tabs-target="tab"
                data-action="click->institution-tabs#select"
                aria-controls="inst-panel-<%= idx %>">
                <%= institution %>
                <span class="ml-1 text-xs font-normal text-zinc-500">(<%= rows.size %>)</span>
              </button>
            <% end %>
          </div>

          <% @institution_tabs.each_with_index do |(institution, rows), idx| %>
            <div
              id="inst-panel-<%= idx %>"
              role="tabpanel"
              aria-labelledby="inst-tab-<%= idx %>"
              class="p-1 sm:p-0"
              data-institution-tabs-target="panel"
              <%= "hidden" if idx != 0 %>>
              <div class="overflow-x-auto px-3 pb-4 pt-3 sm:px-4">
                <p class="mb-3 text-xs text-zinc-500 sm:hidden"><%= institution %> · <%= rows.size %> lançamento(s)</p>
                <table class="min-w-full text-left text-sm">
                  <thead>
                    <tr class="border-b border-zinc-100 bg-zinc-50/80 text-xs font-semibold uppercase tracking-wide text-zinc-500">
                      <th class="px-4 py-3 font-semibold sm:px-5">Data</th>
                      <th class="px-4 py-3 font-semibold sm:px-5">Descrição</th>
                      <th class="px-4 py-3 font-semibold sm:px-5">Tipo</th>
                      <th class="px-4 py-3 text-right font-semibold sm:px-5">Valor</th>
                      <th class="hidden px-4 py-3 font-semibold lg:table-cell sm:px-5">Extrato</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-zinc-100">
                    <% rows.each do |row| %>
                      <tr class="bg-white">
                        <td class="whitespace-nowrap px-4 py-3 text-zinc-800 sm:px-5"><%= row.occurred_on.strftime("%d/%m/%Y") %></td>
                        <td class="max-w-md px-4 py-3 text-zinc-700 sm:px-5"><%= row.description %></td>
                        <td class="px-4 py-3 text-zinc-600 sm:px-5"><%= bank_statement_transaction_type_label(row.transaction_type) %></td>
                        <td class="whitespace-nowrap px-4 py-3 text-right font-medium tabular-nums sm:px-5 <%= bank_statement_amount_text_class(row) %>">
                          <%= bank_statement_amount_currency(row.amount) %>
                        </td>
                        <td class="hidden px-4 py-3 lg:table-cell sm:px-5">
                          <% imp = row.bank_statement_import %>
                          <% if imp.file.attached? %>
                            <%= link_to original_bank_statement_import_path(imp),
                                  class: "inline-flex text-accent hover:text-accent/80 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/40 rounded",
                                  target: "_blank",
                                  rel: "noopener",
                                  title: "Abrir PDF original (import ##{imp.id})",
                                  aria: { label: "Abrir PDF original do import ##{imp.id}" } do %>
                              <%= heroicon "document-text", variant: :outline, options: { class: "h-5 w-5 shrink-0", "aria-hidden": "true" } %>
                            <% end %>
                          <% else %>
                            <%= link_to bank_statement_import_path(imp),
                                  class: "inline-flex text-zinc-400 hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/40 rounded",
                                  title: "Import ##{imp.id} (PDF indisponível)",
                                  aria: { label: "Ver importação ##{imp.id}, PDF indisponível" } do %>
                              <%= heroicon "document-text", variant: :outline, options: { class: "h-5 w-5 shrink-0 opacity-70", "aria-hidden": "true" } %>
                            <% end %>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="app-card p-8 text-center text-sm text-zinc-600">
          <p>Nenhum lançamento ainda. Importe um PDF para começar.</p>
        </div>
      <% end %>
    </section>
  </div>
</div>
