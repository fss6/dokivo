<% content_for :title, "Extratos · #{current_client.name} · Dokivo" %>

<div class="space-y-8">
  <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <nav class="text-xs font-medium text-zinc-500" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li><%= link_to "Clientes", clients_path, class: "text-zinc-500 no-underline hover:text-accent" %></li>
          <li aria-hidden="true">/</li>
          <li><%= link_to current_client.name, current_client, class: "text-zinc-500 no-underline hover:text-accent" %></li>
          <li aria-hidden="true">/</li>
          <li class="text-zinc-700">Extratos</li>
        </ol>
      </nav>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Extratos e lançamentos</h1>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-zinc-600">
        Lista de lançamentos do cliente ativo. Você pode incluir, editar e remover itens manualmente.
        <% if params[:import_id].present? %>
          <%= link_to "Ver todos os lançamentos", bank_statements_path, class: "font-medium text-accent no-underline hover:underline" %>
          (filtro: <%= link_to "import ##{params[:import_id]}", bank_statement_import_path(params[:import_id]), class: "font-medium text-accent no-underline hover:underline" %>).
        <% end %>
      </p>
    </div>
    <div class="flex items-center gap-2">
      <% if policy(BankStatement).create? %>
        <%= link_to "Novo lançamento", new_bank_statement_path, class: "app-btn-primary no-underline" %>
      <% end %>
    </div>
  </header>

  <section class="min-w-0" aria-labelledby="launches-heading">
    <h2 id="launches-heading" class="mb-3 text-sm font-semibold text-zinc-900">Lançamentos</h2>

    <% if @bank_statements.any? %>
      <div class="app-card overflow-hidden">
        <div class="overflow-x-auto px-3 pb-4 pt-3 sm:px-4">
          <table class="min-w-full text-left text-sm">
            <thead>
              <tr class="border-b border-zinc-100 bg-zinc-50/80 text-xs font-semibold uppercase tracking-wide text-zinc-500">
                <th class="px-4 py-3 font-semibold sm:px-5">Data</th>
                <th class="px-4 py-3 font-semibold sm:px-5">Instituição</th>
                <th class="px-4 py-3 font-semibold sm:px-5">Descrição</th>
                <th class="px-4 py-3 font-semibold sm:px-5">Tipo</th>
                <th class="px-4 py-3 text-right font-semibold sm:px-5">Valor</th>
                <th class="hidden px-4 py-3 font-semibold lg:table-cell sm:px-5">Extrato</th>
                <th class="px-4 py-3 text-right font-semibold sm:px-5">Ações</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-100">
              <% @bank_statements.each do |row| %>
                <tr class="bg-white">
                  <td class="whitespace-nowrap px-4 py-3 text-zinc-800 sm:px-5"><%= row.occurred_on.strftime("%d/%m/%Y") %></td>
                  <td class="max-w-[14rem] truncate px-4 py-3 text-zinc-700 sm:px-5" title="<%= row.institution&.name %>"><%= row.institution&.name.presence || "—" %></td>
                  <td class="max-w-md px-4 py-3 text-zinc-700 sm:px-5">
                    <%= row.description %>
                    <% if row.possible_duplicate? %>
                      <span class="ml-2 inline-flex items-center rounded bg-amber-100 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-amber-800">Duplicata?</span>
                    <% end %>
                  </td>
                  <td class="px-4 py-3 text-zinc-600 sm:px-5"><%= bank_statement_transaction_type_label(row.transaction_type) %></td>
                  <td class="whitespace-nowrap px-4 py-3 text-right font-medium tabular-nums sm:px-5 <%= bank_statement_amount_text_class(row) %>">
                    <%= bank_statement_amount_currency(row.amount) %>
                  </td>
                  <td class="hidden px-4 py-3 lg:table-cell sm:px-5">
                    <% imp = row.bank_statement_import %>
                    <% if imp.file.attached? %>
                      <%= link_to original_bank_statement_import_path(imp),
                            class: "inline-flex text-accent hover:text-accent/80 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/40 rounded",
                            target: "_blank",
                            rel: "noopener",
                            title: "Abrir PDF original (import ##{imp.id})",
                            aria: { label: "Abrir PDF original do import ##{imp.id}" } do %>
                        <%= heroicon "document-text", variant: :outline, options: { class: "h-5 w-5 shrink-0", "aria-hidden": "true" } %>
                      <% end %>
                    <% else %>
                      <%= link_to bank_statement_import_path(imp),
                            class: "inline-flex text-zinc-400 hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/40 rounded",
                            title: "Import ##{imp.id} (PDF indisponível)",
                            aria: { label: "Ver importação ##{imp.id}, PDF indisponível" } do %>
                        <%= heroicon "document-text", variant: :outline, options: { class: "h-5 w-5 shrink-0 opacity-70", "aria-hidden": "true" } %>
                      <% end %>
                    <% end %>
                  </td>
                  <td class="whitespace-nowrap px-4 py-3 text-right sm:px-5">
                    <div class="inline-flex items-center gap-3 text-xs font-medium">
                      <% if policy(row).update? %>
                        <%= link_to "Editar", edit_bank_statement_path(row), class: "text-accent no-underline hover:underline" %>
                      <% end %>
                      <% if policy(row).destroy? %>
                        <%= button_to "Excluir",
                              bank_statement_path(row),
                              method: :delete,
                              form: { data: { turbo_confirm: "Excluir este lançamento?" }, class: "inline" },
                              class: "cursor-pointer border-0 bg-transparent p-0 text-red-600 hover:text-red-700" %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <div class="app-card p-8 text-center text-sm text-zinc-600">
        <p>Nenhum lançamento ainda.</p>
      </div>
    <% end %>
  </section>
</div>
