<% content_for :title, "#{@client.name} · Dokivo" %>

<div class="space-y-8" data-controller="app-confirm-modal">
  <header class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <nav class="text-xs font-medium text-zinc-500" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><%= link_to "Clientes", clients_path, class: "text-zinc-500 no-underline hover:text-accent" %></li>
          <li aria-hidden="true">/</li>
          <li class="text-zinc-700"><%= @client.name %></li>
        </ol>
      </nav>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl"><%= @client.name %></h1>
      <dl class="mt-3 grid gap-2 text-sm text-zinc-600 sm:grid-cols-2">
        <div><span class="font-medium text-zinc-500">CNPJ / CPF:</span> <%= @client.tax_id.presence || "—" %></div>
        <div><span class="font-medium text-zinc-500">E-mail:</span> <%= @client.email.presence || "—" %></div>
        <div><span class="font-medium text-zinc-500">Telefone:</span> <%= @client.phone.presence || "—" %></div>
      </dl>
      <% if @client.notes.present? %>
        <div class="mt-4 rounded-lg border border-zinc-100 bg-zinc-50/80 p-4 text-sm text-zinc-700">
          <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Observações</p>
          <p class="mt-2 whitespace-pre-wrap"><%= @client.notes %></p>
        </div>
      <% end %>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Editar", edit_client_path(@client), class: "app-btn-secondary" %>
      <%= button_to "Excluir", @client, method: :delete, form: { data: { turbo_confirm: "Excluir este cliente? Pastas vinculadas ficarão sem cliente." } }, class: "app-btn-secondary border-red-200 text-red-700 hover:border-red-300 hover:bg-red-50" %>
    </div>
  </header>
</div>
