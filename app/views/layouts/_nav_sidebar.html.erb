<aside class="hidden min-h-0 w-14 shrink-0 flex-col self-stretch border-r border-zinc-800/80 bg-zinc-950 lg:flex xl:w-52" aria-label="Navegação principal">
  <div class="flex h-14 items-center justify-center border-b border-zinc-800/80 xl:justify-start xl:px-4">
    <%= link_to root_path, class: "flex items-center gap-2 text-white no-underline" do %>
      <span class="flex h-8 w-8 items-center justify-center rounded-md bg-accent text-sm font-semibold text-white shadow-sm">D</span>
      <span class="hidden text-sm font-semibold tracking-tight xl:inline">Docfy</span>
    <% end %>
  </div>

  <nav class="flex min-h-0 flex-1 flex-col gap-0.5 overflow-y-auto p-2">
    <% nav = [
      { key: :dashboard, label: "Painel", path: dashboard_path, icon: :home },
      { key: :conversations, label: "Conversas", path: nav_chat_path, icon: :conversations },
      { key: :documents_term_search, label: "Busca por termo", path: documents_term_search_path, icon: :search_document },
      { key: :documents_tags_search, label: "Busca por tags", path: documents_tags_search_path, icon: :search },
      { key: :folders, label: "Pastas", path: folders_path, icon: :folder },
      { key: :users, label: "Usuários", path: users_path, icon: :users },
      { key: :plans, label: "Planos", path: plans_path, icon: :plans },
      { key: :accounts, label: "Contas", path: accounts_path, icon: :building }, 
      { key: :groups, label: "Grupos", path: groups_path, icon: :group },
      { key: :subscriptions, label: "Assinaturas", path: subscriptions_path, icon: :credit_card },
      { key: :settings, label: "Configurações", path: settings_path, icon: :cog }
    ] %>
    <% nav.each do |item| %>
      <% active = (item[:key] == :dashboard && (current_page?(root_path) || request.path.start_with?("/dashboard"))) ||
                   (item[:key] == :plans && request.path.start_with?("/plans")) ||
                   (item[:key] == :accounts && request.path.start_with?("/accounts") && !request.path.match?(%r{\A/accounts/\d+/conversations})) ||
                   (item[:key] == :users && request.path.start_with?("/users")) ||
                   (item[:key] == :folders && request.path.start_with?("/folders")) ||
                   (item[:key] == :documents_term_search && request.path.start_with?("/documents/search")) ||
                   (item[:key] == :documents_tags_search && request.path.start_with?("/documents/tags")) ||
                   (item[:key] == :settings && request.path.start_with?("/settings")) ||
                   (item[:key] == :conversations && request.path.match?(%r{\A/accounts/\d+/conversations})) ||
                   (item[:key] == :groups && request.path.start_with?("/groups")) ||
                   (item[:key] == :subscriptions && request.path.start_with?("/subscriptions")) %>
      
      <% allowed = case item[:key]
        when :dashboard then policy(:dashboard).index?
        when :plans then policy(Plan).index?
        when :accounts then policy(Account).index?
        when :users then policy(User).index? 
        when :subscriptions then policy(Subscription).index?
        when :groups then policy(Group).index?
        when :conversations then policy(Conversation).index?
        when :folders then policy(Folder).index?
        when :documents_term_search then policy(Document).index?
        when :documents_tags_search then policy(Document).index?
        when :settings then policy(Setting).show?
        else false
      end %>

      <% next unless allowed %>

      <%= link_to item[:path],
            class: [
              "group flex items-center justify-center gap-3 rounded-md px-2 py-2.5 text-zinc-400 transition-colors no-underline xl:justify-start",
              (active ? "bg-zinc-800/80 text-white" : "hover:bg-zinc-800/60 hover:text-zinc-200")
            ].join(" "),
            data: (item[:key] == :dashboard ? { turbo: false } : {}) do %>
        <%= render "layouts/nav_icon", name: item[:icon] %>
        <span class="hidden text-sm font-medium xl:inline"><%= item[:label] %></span>
      <% end %>
    <% end %>
  </nav>

  <div class="border-t border-zinc-800/80 p-2">
    <div class="hidden rounded-md bg-zinc-900/80 px-3 py-2 xl:block">
      <p class="text-xs font-medium text-zinc-300">Gestão inteligente</p>
      <p class="mt-0.5 text-[11px] leading-snug text-zinc-500">Planos com IA integrada</p>
    </div>
  </div>
</aside>
