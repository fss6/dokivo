<aside class="hidden min-h-0 w-14 shrink-0 flex-col self-stretch border-r border-zinc-800/80 bg-zinc-950 lg:flex xl:w-52" aria-label="Navegação principal">
  <div class="flex h-14 items-center justify-center border-b border-zinc-800/80 xl:justify-start xl:px-4">
    <%= link_to root_path, class: "nav-sidebar-brand flex items-center gap-2 text-white no-underline", aria: { label: "Dokivo — início" } do %>
      <%= image_tag "/brand/logo.svg", alt: "", class: "h-8 w-8 shrink-0", role: "presentation" %>
      <div class="logo-text hidden xl:block">Dok<span>ivo</span></div>
    <% end %>
  </div>

  <nav class="flex min-h-0 flex-1 flex-col gap-2 overflow-y-auto p-2">
    <%# Lançamentos + importação na mesma página; sem cliente activo redireciona com alerta. %>
    <% bank_statements_nav_path = bank_statements_path %>
    <% nav_sections = [
      {
        title: "Visão Geral",
        items: [
          { key: :dashboard, label: "Dashboard", path: dashboard_path, icon: :home, policy_ok: policy(:dashboard).index? },
          { key: :wallet, label: "Carteira", path: wallet_path, icon: :credit_card, policy_ok: policy(Client).index? },
          { key: :clients, label: "Clientes", path: clients_path, icon: :clients, policy_ok: policy(Client).index? },
          { key: :institutions, label: "Instituições", path: institutions_path, icon: :institutions, policy_ok: policy(Institution).index? }
        ]
      },
      {
        title: "Documentos",
        items: [
          { key: :timeline, label: "Timeline", path: timeline_path, icon: :queue_list, disabled: current_client.blank?, policy_ok: policy(Folder).index? },
          { key: :folders, label: "Pastas", path: folders_path, icon: :folder, policy_ok: policy(Folder).index? },
          { key: :bank_statements, label: "Extratos", path: bank_statements_nav_path, icon: :document, policy_ok: policy(BankStatement).index? },
          { key: :conversations, label: "Chat IA", path: nav_chat_path, icon: :conversations, policy_ok: policy(Conversation).index? }
        ]
      },
      {
        title: "Inteligência",
        items: [
          { key: :wiki, label: "Wiki", path: wiki_path, icon: :book_open, policy_ok: WikiPagePolicy.new(current_user, :wiki_page).index? },
          { key: :audit, label: "Auditoria", path: audits_path, icon: :document_text, policy_ok: policy(:audit).index? },
          { key: :monthly_collection, label: "Coleta Mensal", path: monthly_collections_path, icon: :arrow_up_on_square, policy_ok: policy(Folder).index? },
          { key: :erp_export, label: "Exporta ERP", icon: :circle_stack, disabled: true, policy_ok: true }
        ]
      }
    ] %>

    <% nav_sections.each do |section| %>
      <section class="space-y-0.5">
        <p class="hidden px-2 pb-1 pt-1 text-[11px] font-semibold uppercase tracking-wide text-zinc-500 xl:block"><%= section[:title] %></p>
        <% section[:items].each do |item| %>
          <% next unless item[:policy_ok] %>
          <% active = (item[:key] == :dashboard && (current_page?(root_path) || request.path.start_with?("/dashboard"))) ||
                       (item[:key] == :wallet && request.path.start_with?("/wallet")) ||
                       (item[:key] == :clients && request.path.start_with?("/clients")) ||
                       (item[:key] == :institutions && request.path.start_with?("/institutions")) ||
                       (item[:key] == :folders && request.path.start_with?("/folders")) ||
                       (item[:key] == :timeline && request.path.start_with?("/timeline")) ||
                       (item[:key] == :bank_statements && (request.path.start_with?("/bank_statements") || request.path.match?(%r{\A/bank_statement_imports/\d+}))) ||
                       (item[:key] == :conversations && request.path.match?(%r{\A/accounts/\d+/conversations})) ||
                       (item[:key] == :wiki && request.path.start_with?("/wiki")) ||
                       (item[:key] == :audit && request.path.start_with?("/audit")) ||
                       (item[:key] == :monthly_collection && request.path.start_with?("/monthly-collections")) %>

          <% base_classes = "group flex items-center justify-center gap-3 rounded-md px-2 py-2.5 text-zinc-400 transition-colors xl:justify-start" %>
          <% if item[:disabled] %>
            <div class="<%= [base_classes, 'cursor-default opacity-70'].join(' ') %>" aria-disabled="true">
              <%= render "layouts/nav_icon", name: item[:icon] %>
              <span class="hidden text-sm font-medium xl:inline"><%= item[:label] %></span>
            </div>
          <% else %>
            <%= link_to item[:path],
                  class: [
                    base_classes,
                    "no-underline",
                    (active ? "bg-zinc-800/80 text-white" : "hover:bg-zinc-800/60 hover:text-zinc-200")
                  ].join(" "),
                  data: (item[:key] == :dashboard ? { turbo: false } : {}) do %>
              <%= render "layouts/nav_icon", name: item[:icon] %>
              <span class="hidden text-sm font-medium xl:inline"><%= item[:label] %></span>
            <% end %>
          <% end %>
        <% end %>
      </section>
    <% end %>
  </nav>

  <div class="border-t border-zinc-800/80 p-2">
    <div class="hidden rounded-md bg-zinc-900/80 px-3 py-2 xl:block">
      <p class="text-xs font-medium text-zinc-300">Gestão inteligente</p>
      <p class="mt-0.5 text-[11px] leading-snug text-zinc-500">Planos com IA integrada</p>
    </div>
  </div>
</aside>
