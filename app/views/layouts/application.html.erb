<!DOCTYPE html>
<html lang="pt-BR" class="<%= chat_module_page? ? "h-dvh max-h-dvh overflow-hidden" : "h-full" %>">
  <head>
    <title><%= content_for(:title) || "Dokivo" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/brand/favicon.ico" sizes="any">
    <link rel="icon" href="/brand/logo.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/brand/logo_96x96.svg">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400..700;1,14..32,400..700&family=Plus+Jakarta+Sans:wght@800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <% chat_shell = chat_module_page? %>
  <body class="bg-zinc-100 font-sans text-zinc-900 antialiased <%= chat_shell ? "h-dvh overflow-hidden" : "min-h-dvh" %>">
    <div class="flex w-full items-stretch <%= chat_shell ? "h-full min-h-0" : "min-h-dvh" %>">
      <%= render "layouts/nav_sidebar" %>

      <div class="flex min-w-0 flex-1 flex-col <%= chat_shell ? "h-full min-h-0 overflow-hidden" : "min-h-dvh" %>">
        <%= render "layouts/top_bar" %>

        <div class="flex min-h-0 flex-1 items-stretch overflow-hidden">
          <main class="min-w-0 flex-1 <%= chat_shell ? "flex min-h-0 flex-col overflow-hidden" : "overflow-y-auto" %>">
            <div class="flex w-full <%= chat_shell ? "max-w-none flex-1 min-h-0 flex-col px-4 py-4 sm:px-5 lg:px-8 lg:py-5" : "mx-auto min-h-full max-w-[88rem] flex-col px-4 py-6 sm:px-6 lg:px-8 lg:py-8" %>">
              <div class="<%= chat_shell ? "shrink-0" : "" %>">
                <%= render "shared/flash" %>
              </div>
              <div class="<%= chat_shell ? "flex min-h-0 flex-1 flex-col overflow-hidden" : "flex-1" %>">
                <%= yield %>
              </div>
            </div>
          </main>

          <% if content_for?(:right_sidebar) %>
            <aside class="hidden w-80 shrink-0 overflow-y-auto border-l border-zinc-200/80 bg-white shadow-[inset_1px_0_0_0_rgb(0_0_0/0.03)] xl:block">
              <div class="flex min-h-full flex-col p-6">
                <%= yield :right_sidebar %>
              </div>
            </aside>
          <% end %>
        </div>

        <%= render "layouts/app_footer" %>
      </div>
    </div>
  </body>
</html>
