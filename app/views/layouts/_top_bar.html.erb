<header class="sticky top-0 z-10 flex h-14 shrink-0 items-center gap-3 border-b border-zinc-200/90 bg-white px-4 shadow-[0_1px_0_0_rgb(0_0_0/0.03)] sm:px-6">
  <details class="relative lg:hidden">
    <summary class="app-btn-ghost list-none cursor-pointer [&::-webkit-details-marker]:hidden">
      <span class="sr-only">Menu</span>
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
    </summary>
    <div class="absolute left-0 top-full mt-1 w-56 rounded-lg border border-zinc-200 bg-white py-1 shadow-[var(--shadow-float)]">
      <%= link_to "Painel", root_path, class: "block px-4 py-2 text-sm text-zinc-700 no-underline hover:bg-zinc-50" %>
      <%= link_to "Coleções", plans_path, class: "block px-4 py-2 text-sm text-zinc-700 no-underline hover:bg-zinc-50" %>
      <%= link_to "Contas", accounts_path, class: "block px-4 py-2 text-sm text-zinc-700 no-underline hover:bg-zinc-50" %>
      <%= link_to "Usuários", users_path, class: "block px-4 py-2 text-sm text-zinc-700 no-underline hover:bg-zinc-50" %>
      <%= link_to "Pastas", folders_path, class: "block px-4 py-2 text-sm text-zinc-700 no-underline hover:bg-zinc-50" %>
      <%= link_to "Grupos", groups_path, class: "block px-4 py-2 text-sm text-zinc-700 no-underline hover:bg-zinc-50" %>
      <%= link_to "Assinaturas", subscriptions_path, class: "block px-4 py-2 text-sm text-zinc-700 no-underline hover:bg-zinc-50" %>
    </div>
  </details>

  <form action="#" method="get" class="relative min-w-0 flex-1 max-w-xl" role="search">
    <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-accent" aria-hidden="true">
      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.847a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.847.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.455 2.456Z" /></svg>
    </span>
    <label for="global-search" class="sr-only">Buscar na coleção</label>
    <input id="global-search" type="search" name="q" placeholder="Buscar ativos, metadados ou insights de IA…" class="app-input pl-10 pr-4" autocomplete="off" />
  </form>

  <div class="flex shrink-0 items-center gap-2">
    <span class="hidden text-xs font-medium text-zinc-500 sm:inline">IA Insights</span>
    <button type="button" class="flex h-9 w-9 items-center justify-center rounded-full border border-zinc-200 bg-zinc-50 text-sm font-semibold text-zinc-700 shadow-sm transition-colors hover:border-zinc-300 hover:bg-white" aria-label="Conta">
      FS
    </button>
  </div>
</header>
