<% content_for :title, "Extrato ##{@bank_statement_import.id} · #{current_client.name} · Dokivo" %>

<div class="space-y-8">
  <header class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <nav class="text-xs font-medium text-zinc-500" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li><%= link_to "Clientes", clients_path, class: "text-zinc-500 no-underline hover:text-accent" %></li>
          <li aria-hidden="true">/</li>
          <li><%= link_to current_client.name, current_client, class: "text-zinc-500 no-underline hover:text-accent" %></li>
          <li aria-hidden="true">/</li>
          <li><%= link_to "Extratos", bank_statements_path, class: "text-zinc-500 no-underline hover:text-accent" %></li>
          <li aria-hidden="true">/</li>
          <li class="text-zinc-700">#<%= @bank_statement_import.id %></li>
        </ol>
      </nav>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">Extrato bancário</h1>
      <p class="mt-2 text-sm text-zinc-600">
        Instituição:
        <span class="font-semibold text-zinc-800"><%= @bank_statement_import.institution&.name || "—" %></span>
        · Estado:
        <span class="font-semibold text-zinc-800"><%= @bank_statement_import.status.humanize %></span>
        · <%= @bank_statement_import.created_at.strftime("%d/%m/%Y %H:%M") %>
      </p>
      <% if @bank_statement_import.pending? || @bank_statement_import.processing? %>
        <p class="mt-3 text-sm text-amber-800">
          A processar o PDF. <%= link_to "Recarregar esta página", bank_statement_import_path(@bank_statement_import), class: "font-medium text-accent underline" %> daqui a instantes.
        </p>
      <% end %>
      <% if @bank_statement_import.failed? && @bank_statement_import.metadata["error"].present? %>
        <div class="mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900">
          <p class="font-medium">Erro</p>
          <p class="mt-1"><%= @bank_statement_import.metadata.dig("error", "message") %></p>
        </div>
      <% end %>
    </div>
    <div class="flex flex-col gap-2 sm:items-end">
      <%= link_to "Voltar aos extratos", bank_statements_path, class: "app-btn-secondary" %>
      <% if @bank_statement_import.completed? && @bank_statement_import.bank_statements.any? %>
        <%= link_to "Ver estes lançamentos", bank_statements_path(import_id: @bank_statement_import.id), class: "app-btn-primary text-center" %>
      <% end %>
    </div>
  </header>

  <% if @bank_statement_import.completed? && @bank_statement_import.bank_statements.any? %>
    <section class="app-card overflow-hidden" aria-labelledby="tx-heading">
      <div class="border-b border-zinc-100 px-5 py-4 sm:px-6">
        <h2 id="tx-heading" class="text-sm font-semibold text-zinc-900">Lançamentos (<%= @bank_statement_import.bank_statements.size %>)</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-left text-sm">
          <thead>
            <tr class="border-b border-zinc-100 bg-zinc-50/80 text-xs font-semibold uppercase tracking-wide text-zinc-500">
              <th class="px-5 py-3 font-semibold sm:px-6">Data</th>
              <th class="px-5 py-3 font-semibold sm:px-6">Instituição (extrato)</th>
              <th class="px-5 py-3 font-semibold sm:px-6">Descrição</th>
              <th class="px-5 py-3 font-semibold sm:px-6">Tipo</th>
              <th class="px-5 py-3 text-right font-semibold sm:px-6">Valor</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-100">
            <% @bank_statement_import.bank_statements.order(occurred_on: :desc, id: :desc).each do |row| %>
              <tr class="bg-white">
                <td class="whitespace-nowrap px-5 py-3 text-zinc-800 sm:px-6"><%= row.occurred_on.strftime("%d/%m/%Y") %></td>
                <td class="px-5 py-3 text-zinc-600 sm:px-6"><%= row.institution&.name.presence || "—" %></td>
                <td class="max-w-md px-5 py-3 text-zinc-700 sm:px-6"><%= row.description %></td>
                <td class="px-5 py-3 text-zinc-600 sm:px-6"><%= bank_statement_transaction_type_label(row.transaction_type) %></td>
                <td class="whitespace-nowrap px-5 py-3 text-right font-medium tabular-nums sm:px-6 <%= bank_statement_amount_text_class(row) %>">
                  <%= bank_statement_amount_currency(row.amount) %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% elsif @bank_statement_import.completed? %>
    <div class="app-card p-6 text-sm text-zinc-600">
      Processamento concluído, mas não foram encontradas transações no extrato.
    </div>
  <% end %>
</div>
